{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'page_title'|trans({}, 'dashboard') }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto">

    {# Encabezado de página #}
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">{{ 'page_title'|trans({}, 'dashboard') }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ 'welcome_message'|trans({}, 'dashboard') }}</p>
    </div>

    {# Tarjetas de estadísticas — pendientes de definir #}
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-4">
        {% for i in 1..4 %}
            <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-xs">
                <div class="h-4 w-24 rounded bg-gray-100 animate-pulse"></div>
                <div class="mt-4 h-8 w-16 rounded bg-gray-100 animate-pulse"></div>
                <div class="mt-2 h-3 w-32 rounded bg-gray-100 animate-pulse"></div>
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}
