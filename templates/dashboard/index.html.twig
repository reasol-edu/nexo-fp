{% extends 'base.html.twig' %}

{% block title %}{{ 'page_title'|trans({}, 'dashboard') }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-plum-50 flex flex-col items-center justify-center gap-4">
    <div class="w-12 h-12 rounded-2xl bg-plum-600 flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-1.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
        </svg>
    </div>
    <h1 class="text-2xl font-bold text-plum-900">{{ app_name }}</h1>
    <p class="text-plum-600">{{ 'welcome_message'|trans({}, 'dashboard') }}</p>
    <a href="{{ path('app_logout') }}"
       class="mt-2 text-sm text-plum-500 hover:text-plum-700 underline underline-offset-2 transition-colors">
        {{ 'logout'|trans({}, 'dashboard') }}
    </a>
</div>
{% endblock %}
