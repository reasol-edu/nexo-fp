{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'stays.edit.title'|trans({}, 'stays') }} · {{ stay.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto">

    <div class="mb-6">
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            <a href="{{ path('app_stays_index') }}" class="hover:text-plum-600 transition-colors">
                {{ 'stays.title'|trans({}, 'stays') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_stays_show', {id: stay.id.toRfc4122}) }}"
               class="hover:text-plum-600 transition-colors truncate max-w-48">
                {{ stay.name }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'stays.edit.title'|trans({}, 'stays') }}</h1>
        {% if centre.activeAcademicYear %}
            <p class="mt-1 text-sm text-gray-500">{{ centre.name }} · {{ centre.activeAcademicYear.name }}</p>
        {% endif %}
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <form method="post" class="px-6 py-6 space-y-5" data-controller="form-submit">
            <input type="hidden" name="_token" value="{{ csrf_token('edit_stay_' ~ stay.id.toRfc4122) }}">

            {% if errors is defined and errors|length > 0 %}
                <div role="alert" class="rounded-xl border border-red-200 bg-red-50 px-4 py-3">
                    <p class="text-sm font-medium text-red-800 mb-1">{{ 'stays.form.error_summary'|trans({}, 'stays') }}</p>
                    <ul class="list-disc list-inside text-xs text-red-700 space-y-0.5">
                        {% for msg in errors %}
                            <li>{{ msg }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            {# Nombre #}
            <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.field.name'|trans({}, 'stays') }}
                    <span class="text-red-400 ml-0.5">*</span>
                </label>
                <input id="name" type="text" name="name"
                       value="{{ values.name }}"
                       placeholder="{{ 'stays.field.name_placeholder'|trans({}, 'stays') }}"
                       autofocus
                       class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                              transition-colors focus:outline-none focus:ring-3
                              {{ errors.name is defined
                                  ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                  : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                {% if errors.name is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.name }}</p>
                {% endif %}
            </div>

            {# Enseñanza (solo lectura) #}
            <div>
                <span class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.field.programme'|trans({}, 'stays') }}
                </span>
                <div class="flex items-center gap-2 rounded-xl border border-gray-200 bg-gray-100 py-2.5 px-3.5">
                    <span class="text-sm text-gray-500">{{ stay.programme.professionalFamily.name }}</span>
                    <span class="text-gray-300">·</span>
                    <span class="text-sm text-gray-700 font-medium">{{ stay.programme.name }}</span>
                </div>
            </div>

            {# Fechas #}
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                    <label for="start_date" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'stays.field.start_date'|trans({}, 'stays') }}
                        <span class="text-red-400 ml-0.5">*</span>
                    </label>
                    <input id="start_date" type="date" name="start_date"
                           value="{{ values.start_date }}"
                           class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                  transition-colors focus:outline-none focus:ring-3
                                  {{ errors.start_date is defined
                                      ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                      : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                    {% if errors.start_date is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.start_date }}</p>
                    {% endif %}
                </div>
                <div>
                    <label for="end_date" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'stays.field.end_date'|trans({}, 'stays') }}
                        <span class="text-red-400 ml-0.5">*</span>
                    </label>
                    <input id="end_date" type="date" name="end_date"
                           value="{{ values.end_date }}"
                           class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                  transition-colors focus:outline-none focus:ring-3
                                  {{ errors.end_date is defined
                                      ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                      : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                    {% if errors.end_date is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.end_date }}</p>
                    {% endif %}
                </div>
            </div>

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_stays_show', {id: stay.id.toRfc4122}) }}"
                   class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm font-medium text-gray-700
                          hover:bg-gray-50 transition-colors">
                    {{ 'stays.cancel'|trans({}, 'stays') }}
                </a>
                <button type="submit"
                        class="rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                               hover:bg-plum-700 transition-colors shadow-xs">
                    {{ 'stays.edit.save'|trans({}, 'stays') }}
                </button>
            </div>
        </form>
    </div>

</div>

<script>
(function () {
    const start = document.getElementById('start_date');
    const end   = document.getElementById('end_date');
    if (!start || !end) return;
    function syncMin() {
        if (start.value) {
            end.min = start.value;
            if (end.value && end.value < start.value) end.value = start.value;
        } else {
            end.removeAttribute('min');
        }
    }
    start.addEventListener('change', syncMin);
    syncMin();
}());
</script>
{% endblock %}
