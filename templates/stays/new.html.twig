{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'stays.new.title'|trans({}, 'stays') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto">

    <div class="mb-6">
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
            <a href="{{ path('app_stays_index') }}" class="hover:text-plum-600 transition-colors">
                {{ 'stays.title'|trans({}, 'stays') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'stays.new.title'|trans({}, 'stays') }}</h1>
        {% if centre.activeAcademicYear %}
            <p class="mt-1 text-sm text-gray-500">{{ centre.name }} · {{ centre.activeAcademicYear.name }}</p>
        {% endif %}
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <form method="post" class="px-6 py-6 space-y-5">
            <input type="hidden" name="_token" value="{{ csrf_token('new_stay') }}">

            {# Nombre #}
            <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.field.name'|trans({}, 'stays') }}
                </label>
                <input id="name" type="text" name="name"
                       value="{{ values.name }}"
                       placeholder="{{ 'stays.field.name_placeholder'|trans({}, 'stays') }}"
                       autofocus
                       class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                              transition-colors focus:outline-none focus:ring-3
                              {{ errors.name is defined
                                  ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                  : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                {% if errors.name is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.name }}</p>
                {% endif %}
            </div>

            {# Enseñanza #}
            <div>
                <label for="programme_id" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.field.programme'|trans({}, 'stays') }}
                </label>
                <select id="programme_id" name="programme_id"
                        class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                               transition-colors focus:outline-none focus:ring-3
                               {{ errors.programme_id is defined
                                   ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                   : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                    <option value="">{{ 'stays.field.programme_placeholder'|trans({}, 'stays') }}</option>
                    {% for group in by_family %}
                        <optgroup label="{{ group.family.name }}">
                            {% for p in group.programmes %}
                                <option value="{{ p.id }}" {{ values.programme_id == p.id.toRfc4122 ? 'selected' : '' }}>
                                    {{ p.name }}
                                </option>
                            {% endfor %}
                        </optgroup>
                    {% endfor %}
                </select>
                {% if errors.programme_id is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.programme_id }}</p>
                {% endif %}
            </div>

            {# Fechas #}
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                    <label for="start_date" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'stays.field.start_date'|trans({}, 'stays') }}
                        <span class="text-gray-400 font-normal">(opcional)</span>
                    </label>
                    <input id="start_date" type="date" name="start_date"
                           value="{{ values.start_date }}"
                           class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                  transition-colors focus:outline-none focus:ring-3
                                  {{ errors.start_date is defined
                                      ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                      : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                    {% if errors.start_date is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.start_date }}</p>
                    {% endif %}
                </div>
                <div>
                    <label for="end_date" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'stays.field.end_date'|trans({}, 'stays') }}
                        <span class="text-gray-400 font-normal">(opcional)</span>
                    </label>
                    <input id="end_date" type="date" name="end_date"
                           value="{{ values.end_date }}"
                           class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                  transition-colors focus:outline-none focus:ring-3
                                  {{ errors.end_date is defined
                                      ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                      : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                    {% if errors.end_date is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.end_date }}</p>
                    {% endif %}
                </div>
            </div>

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_stays_index') }}"
                   class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm font-medium text-gray-700
                          hover:bg-gray-50 transition-colors">
                    {{ 'stays.cancel'|trans({}, 'stays') }}
                </a>
                <button type="submit"
                        class="rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                               hover:bg-plum-700 transition-colors shadow-xs">
                    {{ 'stays.save'|trans({}, 'stays') }}
                </button>
            </div>
        </form>
    </div>

</div>
{% endblock %}
