{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'stays.position.new_title'|trans({}, 'stays') }} · {{ stay.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto">

    <div class="mb-6">
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            <a href="{{ path('app_stays_index') }}" class="hover:text-plum-600 transition-colors">
                {{ 'stays.title'|trans({}, 'stays') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_stays_show', {id: stay.id.toRfc4122}) }}" class="hover:text-plum-600 transition-colors truncate max-w-48">
                {{ stay.name }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'stays.position.new_title'|trans({}, 'stays') }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ stay.name }} · {{ stay.programme.name }}</p>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs">
        <form method="post" class="px-6 py-6 space-y-5">
            <input type="hidden" name="_token" value="{{ csrf_token('new_position_' ~ stay.id.toRfc4122) }}">

            {# Centro de trabajo #}
            <div>
                <label for="workcenter_id" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.position.field.workcenter'|trans({}, 'stays') }}
                    <span class="text-red-400 ml-0.5">*</span>
                </label>
                <select id="workcenter_id" name="workcenter_id"
                        data-ts-has-error="{{ errors.workcenter_id is defined ? '1' : '' }}"
                        class="w-full text-sm">
                    <option value="">{{ 'stays.position.field.workcenter_placeholder'|trans({}, 'stays') }}</option>
                    {% for group in by_company %}
                        {% for wc in group.workcenters %}
                            <option value="{{ wc.id.toRfc4122 }}"
                                    data-company="{{ group.company.name|e('html_attr') }}"
                                    data-city="{{ wc.city ? wc.city|e('html_attr') : '' }}"
                                    {{ values.workcenter_id == wc.id.toRfc4122 ? 'selected' : '' }}>
                                {{ wc.name }}
                            </option>
                        {% endfor %}
                    {% endfor %}
                </select>
                {% if errors.workcenter_id is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.workcenter_id }}</p>
                {% endif %}
            </div>

            {# Niveles #}
            {% if programme_years is not empty %}
            <div>
                <span class="block text-sm font-medium text-gray-700 mb-2">
                    {{ 'stays.position.field.programme_years'|trans({}, 'stays') }}
                    <span class="text-red-400 ml-0.5">*</span>
                </span>
                {% if errors.programme_year_ids is defined %}
                    <p class="mb-2 text-xs text-red-600">{{ errors.programme_year_ids }}</p>
                {% endif %}
                <div class="flex flex-wrap gap-2">
                    {% for py in programme_years %}
                        <label class="inline-flex items-center gap-2 rounded-xl border px-3 py-2 cursor-pointer
                                       text-sm transition-colors
                                       border-gray-200 bg-gray-50 text-gray-700
                                       hover:border-plum-300 hover:bg-plum-50
                                       has-[:checked]:border-plum-400 has-[:checked]:bg-plum-50 has-[:checked]:text-plum-700">
                            <input type="checkbox"
                                   name="programme_year_ids[]"
                                   value="{{ py.id.toRfc4122 }}"
                                   class="sr-only peer"
                                   {{ py.id.toRfc4122 in values.programme_year_ids ? 'checked' : '' }}>
                            <span class="h-1.5 w-1.5 rounded-full shrink-0 bg-gray-300 peer-checked:bg-green-500"></span>
                            {{ py.name }}
                        </label>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# Observaciones #}
            <div>
                <label for="details" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.position.field.details'|trans({}, 'stays') }}
                    <span class="text-gray-400 font-normal">({{ 'stays.position.optional'|trans({}, 'stays') }})</span>
                </label>
                <textarea id="details" name="details" rows="3"
                          placeholder="{{ 'stays.position.field.details_placeholder'|trans({}, 'stays') }}"
                          class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900 resize-none
                                 border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20
                                 transition-colors focus:outline-none focus:ring-3">{{ values.details }}</textarea>
            </div>

            {# Número de puestos #}
            <div>
                <label for="count" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.position.field.count'|trans({}, 'stays') }}
                </label>
                <div class="flex items-start gap-3">
                    <input id="count" type="number" name="count"
                           value="{{ values.count }}"
                           min="1" max="50"
                           class="w-28 rounded-xl border py-2.5 px-3.5 text-sm text-gray-900 tabular-nums
                                  transition-colors focus:outline-none focus:ring-3
                                  {{ errors.count is defined
                                      ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                      : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                    <p class="pt-2.5 text-xs text-gray-500 leading-relaxed">
                        {{ 'stays.position.field.count_hint'|trans({}, 'stays') }}
                    </p>
                </div>
                {% if errors.count is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.count }}</p>
                {% endif %}
            </div>

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_stays_show', {id: stay.id.toRfc4122}) }}"
                   class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm font-medium text-gray-700
                          hover:bg-gray-50 transition-colors">
                    {{ 'stays.cancel'|trans({}, 'stays') }}
                </a>
                <button type="submit"
                        class="rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                               hover:bg-plum-700 transition-colors shadow-xs">
                    {{ 'stays.position.save'|trans({}, 'stays') }}
                </button>
            </div>
        </form>
    </div>

</div>

<script type="module">
import TomSelect from 'tom-select';

const el = document.getElementById('workcenter_id');
if (el) {

const currentValue = el.value;
const placeholder  = el.querySelector('option[value=""]')?.textContent.trim() ?? '';

// Build flat options list; company + workcenter + city all searchable
const options = [{ value: '', text: placeholder, company: '', name: '', city: '' }];

el.querySelectorAll('option[data-company]').forEach(opt => {
    options.push({
        value:   opt.value,
        text:    opt.textContent.trim(),
        company: opt.dataset.company ?? '',
        name:    opt.textContent.trim(),
        city:    opt.dataset.city    ?? '',
        search:  `${opt.dataset.company} ${opt.textContent.trim()} ${opt.dataset.city ?? ''}`,
    });
});

const ts = new TomSelect(el, {
    options,
    items:        currentValue ? [currentValue] : [],
    valueField:   'value',
    labelField:   'text',
    searchField:  ['search'],
    allowEmptyOption: true,
    create:       false,
    maxOptions:   null,
    placeholder,
    wrapperClass: 'ts-wrapper ts-local',
    plugins:      ['clear_button'],
    render: {
        // Dropdown option: empresa (prominente) + centro de trabajo (subtítulo)
        option: (d, esc) => {
            if (!d.company) return `<div class="py-0.5 text-gray-400 italic">${esc(d.text)}</div>`;
            const city = d.city ? ` <span class="ts-wc-city">· ${esc(d.city)}</span>` : '';
            return `<div class="ts-wc-option">
                        <p class="ts-wc-company">${esc(d.company)}</p>
                        <p class="ts-wc-sub">${esc(d.name)}${city}</p>
                    </div>`;
        },
        // Item seleccionado: empresa · centro (en línea)
        item: (d, esc) => {
            if (!d.company) return `<div>${esc(d.text)}</div>`;
            return `<div class="ts-wc-item">
                        <span class="ts-wc-company">${esc(d.company)}</span>
                        <span class="ts-wc-sep">·</span>
                        <span class="ts-wc-sub">${esc(d.name)}</span>
                    </div>`;
        },
        no_results: () =>
            `<div class="no-results px-3 py-2 text-sm">{{ 'stays.position.field.workcenter_no_results'|trans({}, 'stays') }}</div>`,
    },
});

if (el.dataset.tsHasError) ts.wrapper.classList.add('has-error');

} // end if (el)
</script>
{% endblock %}
