{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'stays.position.edit.title'|trans({}, 'stays') }} · {{ stay.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto">

    <div class="mb-6">
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            <a href="{{ path('app_stays_index') }}" class="hover:text-plum-600 transition-colors">
                {{ 'stays.title'|trans({}, 'stays') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_stays_show', {id: stay.id.toRfc4122}) }}" class="hover:text-plum-600 transition-colors truncate max-w-48">
                {{ stay.name }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'stays.position.edit.title'|trans({}, 'stays') }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ stay.name }} · {{ stay.programme.name }}</p>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs">
        <form method="post" class="px-6 py-6 space-y-5">
            <input type="hidden" name="_token" value="{{ csrf_token('edit_position_' ~ position.id.toRfc4122) }}">

            {% if is_assignment_locked %}
                <div class="rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-800">
                    {{ 'stays.position.assignment_locked_hint'|trans({}, 'stays') }}
                </div>
            {% endif %}

            {# ── Centro de trabajo ────────────────────────────────────────────── #}
            <div>
                <label for="workcenter_id" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.position.field.workcenter'|trans({}, 'stays') }}
                    <span class="text-red-400 ml-0.5">*</span>
                </label>
                <select id="workcenter_id" name="workcenter_id"
                        data-ts-has-error="{{ errors.workcenter_id is defined ? '1' : '' }}"
                        autofocus
                        {{ is_assignment_locked ? 'disabled' : '' }}
                        class="w-full text-sm">
                    <option value="">{{ 'stays.position.field.workcenter_placeholder'|trans({}, 'stays') }}</option>
                    {% for group in by_company %}
                        {% for wc in group.workcenters %}
                            <option value="{{ wc.id.toRfc4122 }}"
                                    data-company="{{ group.company.name|e('html_attr') }}"
                                    data-company-id="{{ group.company.id.toRfc4122 }}"
                                    data-city="{{ wc.city ? wc.city|e('html_attr') : '' }}"
                                    {{ values.workcenter_id == wc.id.toRfc4122 ? 'selected' : '' }}>
                                {{ wc.name }}
                            </option>
                        {% endfor %}
                    {% endfor %}
                </select>
                {% if errors.workcenter_id is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.workcenter_id }}</p>
                {% endif %}
            </div>

            {# ── Niveles ──────────────────────────────────────────────────────── #}
            {% if programme_years is not empty %}
            <div>
                <span class="block text-sm font-medium text-gray-700 mb-2">
                    {{ 'stays.position.field.programme_years'|trans({}, 'stays') }}
                    <span class="text-red-400 ml-0.5">*</span>
                </span>
                {% if errors.programme_year_ids is defined %}
                    <p class="mb-2 text-xs text-red-600">{{ errors.programme_year_ids }}</p>
                {% endif %}
                <div class="flex flex-wrap gap-2">
                    {% for py in programme_years %}
                        <label class="inline-flex items-center gap-2 rounded-xl border px-3 py-2 cursor-pointer
                                       text-sm transition-colors
                                       border-gray-200 bg-gray-50 text-gray-700
                                       hover:border-plum-300 hover:bg-plum-50
                                       has-[:checked]:border-plum-400 has-[:checked]:bg-plum-50 has-[:checked]:text-plum-700">
                            <input type="checkbox"
                                   name="programme_year_ids[]"
                                   value="{{ py.id.toRfc4122 }}"
                                   {{ is_assignment_locked ? 'disabled' : '' }}
                                   class="sr-only peer"
                                   {{ py.id.toRfc4122 in values.programme_year_ids ? 'checked' : '' }}>
                            <span class="h-1.5 w-1.5 rounded-full shrink-0 bg-gray-300 peer-checked:bg-green-500"></span>
                            {{ py.name }}
                        </label>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# ── Estudiante ───────────────────────────────────────────────────── #}
            <div>
                <label for="student_id" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.position.field.student'|trans({}, 'stays') }}
                    <span class="text-gray-400 font-normal">({{ 'stays.position.optional'|trans({}, 'stays') }})</span>
                </label>
                <select id="student_id" name="student_id"
                        data-ts-has-error="{{ errors.student_id is defined ? '1' : '' }}"
                        {{ is_assignment_locked ? 'disabled' : '' }}
                        class="w-full text-sm">
                    <option value="">{{ 'stays.position.field.student_unassigned'|trans({}, 'stays') }}</option>
                    {% for sid, student in enrolled_students %}
                        <option value="{{ sid }}"
                                data-group="{{ student_group_map[sid] is defined ? student_group_map[sid].name|e('html_attr') : '' }}"
                                data-nie="{{ student.studentId|e('html_attr') }}"
                                data-disabled="{{ other_assigned_ids[sid] is defined ? '1' : '' }}"
                                {{ values.student_id == sid ? 'selected' : '' }}>
                            {{ student.name.lastName }} {{ student.name.firstName }}
                        </option>
                    {% endfor %}
                </select>
                {% if errors.student_id is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.student_id }}</p>
                {% endif %}
            </div>

            {# ── Tutor dual docente ────────────────────────────────────────────── #}
            <div>
                <label for="academic_tutor_id" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.position.field.academic_tutor'|trans({}, 'stays') }}
                    <span class="text-gray-400 font-normal">({{ 'stays.position.optional'|trans({}, 'stays') }})</span>
                </label>
                <select id="academic_tutor_id" name="academic_tutor_id"
                        data-ts-has-error="{{ errors.academic_tutor_id is defined ? '1' : '' }}"
                        {{ is_assignment_locked ? 'disabled' : '' }}
                        class="w-full text-sm">
                    <option value="">{{ 'stays.position.field.academic_tutor_placeholder'|trans({}, 'stays') }}</option>
                    {% for teacher in teachers %}
                        <option value="{{ teacher.id.toRfc4122 }}"
                                {{ values.academic_tutor_id == teacher.id.toRfc4122 ? 'selected' : '' }}>
                            {{ teacher.name.lastName }} {{ teacher.name.firstName }}
                        </option>
                    {% endfor %}
                </select>
                {% if errors.academic_tutor_id is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.academic_tutor_id }}</p>
                {% endif %}
            </div>

            {# ── Tutor dual de empresa ─────────────────────────────────────────── #}
            <div>
                <label for="workplace_mentor_id" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.position.field.workplace_mentor'|trans({}, 'stays') }}
                    <span class="text-gray-400 font-normal">({{ 'stays.position.optional'|trans({}, 'stays') }})</span>
                </label>
                <select id="workplace_mentor_id" name="workplace_mentor_id"
                        data-ts-has-error="{{ errors.workplace_mentor_id is defined ? '1' : '' }}"
                        {{ is_assignment_locked ? 'disabled' : '' }}
                        class="w-full text-sm">
                    <option value="">{{ 'stays.position.field.workplace_mentor_placeholder'|trans({}, 'stays') }}</option>
                    {% for cid, workers in workers_by_company %}
                        {% for w in workers %}
                            <option value="{{ w.id.toRfc4122 }}"
                                    data-company-id="{{ cid }}"
                                    {{ values.workplace_mentor_id == w.id.toRfc4122 ? 'selected' : '' }}>
                                {{ w.name.lastName }} {{ w.name.firstName }}
                            </option>
                        {% endfor %}
                    {% endfor %}
                </select>
                {% if errors.workplace_mentor_id is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.workplace_mentor_id }}</p>
                {% endif %}
            </div>

            {# ── Estado ───────────────────────────────────────────────────────── #}
            <div>
                <p class="block text-sm font-medium text-gray-700 mb-2">
                    {{ 'stays.position.field.state'|trans({}, 'stays') }}
                </p>
                <div class="flex gap-2">

                    <label class="group flex flex-1 items-center gap-2.5 rounded-xl border px-3.5 py-3 cursor-pointer transition-all
                                  border-gray-200 bg-gray-50
                                  has-[:checked]:border-gray-400 has-[:checked]:bg-white has-[:checked]:shadow-xs
                                  has-[:disabled]:opacity-40 has-[:disabled]:cursor-not-allowed has-[:disabled]:pointer-events-none
                                  has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-gray-400/50">
                        <input type="radio" name="state" value="DRAFT"
                               {{ values.state == 'DRAFT' ? 'checked' : '' }}
                               class="sr-only">
                        <span class="h-2.5 w-2.5 rounded-full bg-gray-400 shrink-0 ring-2 ring-transparent group-has-[:checked]:ring-gray-300 transition-all"></span>
                        <span class="text-sm font-medium text-gray-700">{{ 'stays.state.draft'|trans({}, 'stays') }}</span>
                    </label>

                    <label class="group flex flex-1 items-center gap-2.5 rounded-xl border px-3.5 py-3 cursor-pointer transition-all
                                  border-gray-200 bg-gray-50
                                  has-[:checked]:border-amber-400 has-[:checked]:bg-amber-50 has-[:checked]:shadow-xs
                                  has-[:disabled]:opacity-40 has-[:disabled]:cursor-not-allowed has-[:disabled]:pointer-events-none
                                  has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-amber-400/50">
                        <input type="radio" name="state" value="PENDING"
                               {{ values.state == 'PENDING' ? 'checked' : '' }}
                               class="sr-only">
                        <span class="h-2.5 w-2.5 rounded-full bg-amber-400 shrink-0 ring-2 ring-transparent group-has-[:checked]:ring-amber-200 transition-all"></span>
                        <span class="text-sm font-medium text-gray-700">{{ 'stays.state.pending'|trans({}, 'stays') }}</span>
                    </label>

                    <label class="group flex flex-1 items-center gap-2.5 rounded-xl border px-3.5 py-3 cursor-pointer transition-all
                                  border-gray-200 bg-gray-50
                                  has-[:checked]:border-green-500 has-[:checked]:bg-green-50 has-[:checked]:shadow-xs
                                  has-[:disabled]:opacity-40 has-[:disabled]:cursor-not-allowed has-[:disabled]:pointer-events-none
                                  has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-green-500/50">
                        <input type="radio" name="state" value="DONE"
                               {{ values.state == 'DONE' ? 'checked' : '' }}
                               class="sr-only">
                        <span class="h-2.5 w-2.5 rounded-full bg-green-500 shrink-0 ring-2 ring-transparent group-has-[:checked]:ring-green-200 transition-all"></span>
                        <span class="text-sm font-medium text-gray-700">{{ 'stays.state.done'|trans({}, 'stays') }}</span>
                    </label>

                </div>
                <p id="state-tutors-hint" class="mt-1.5 text-xs text-amber-600 hidden">
                    {{ 'stays.position.state_locked_hint'|trans({}, 'stays') }}
                </p>
                {% if errors.state is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.state }}</p>
                {% endif %}
            </div>

            {# ── Firmado ───────────────────────────────────────────────────────── #}
            <div>
                <label id="signed-label"
                       class="inline-flex items-start gap-3 rounded-xl border px-4 py-3 transition-colors
                              border-gray-200 bg-gray-50
                              has-[:checked]:border-green-300 has-[:checked]:bg-green-50">
                    <input type="checkbox" id="signed-checkbox" name="signed" value="1"
                           {{ values.signed ? 'checked' : '' }}
                           class="mt-0.5 h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500 shrink-0">
                    <div>
                        <p class="text-sm font-medium text-gray-900">{{ 'stays.position.field.signed'|trans({}, 'stays') }}</p>
                        <p class="text-xs text-gray-500 mt-0.5">{{ 'stays.position.field.signed_hint'|trans({}, 'stays') }}</p>
                    </div>
                </label>
                {% if errors.signed is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.signed }}</p>
                {% endif %}
            </div>

            {# ── Observaciones ────────────────────────────────────────────────── #}
            <div>
                <label for="details" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'stays.position.field.details'|trans({}, 'stays') }}
                    <span class="text-gray-400 font-normal">({{ 'stays.position.optional'|trans({}, 'stays') }})</span>
                </label>
                <textarea id="details" name="details" rows="3"
                          placeholder="{{ 'stays.position.field.details_placeholder'|trans({}, 'stays') }}"
                          class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900 resize-none
                                 border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20
                                 transition-colors focus:outline-none focus:ring-3">{{ values.details }}</textarea>
            </div>

            {# ── Acciones ─────────────────────────────────────────────────────── #}
            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_stays_show', {id: stay.id.toRfc4122}) }}"
                   class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm font-medium text-gray-700
                          hover:bg-gray-50 transition-colors">
                    {{ 'stays.cancel'|trans({}, 'stays') }}
                </a>
                <button type="submit"
                        class="rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                               hover:bg-plum-700 transition-colors shadow-xs">
                    {{ 'stays.position.edit.save'|trans({}, 'stays') }}
                </button>
            </div>
        </form>
    </div>

</div>

<script type="module">
import TomSelect from 'tom-select';

const elWc      = document.getElementById('workcenter_id');
const elMentor  = document.getElementById('workplace_mentor_id');
const elTutor   = document.getElementById('academic_tutor_id');
const elStudent = document.getElementById('student_id');
const isAssignmentLocked = {{ is_assignment_locked ? 'true' : 'false' }};

// ── Workers by company for dynamic mentor filtering ───────────────────────
const WORKERS_BY_COMPANY = {
    {% for cid, workers in workers_by_company %}
    {{ cid|json_encode|raw }}: [
        {% for w in workers %}
        { value: {{ w.id.toRfc4122|json_encode|raw }}, text: {{ (w.name.lastName ~ ' ' ~ w.name.firstName)|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }} },
        {% endfor %}
    ],
    {% endfor %}
};

// ── Shared render helpers ─────────────────────────────────────────────────
function renderTwoLineOption(esc, main, sub) {
    return `<div class="ts-wc-option">
                <p class="ts-wc-company">${esc(main)}</p>
                <p class="ts-wc-sub">${esc(sub)}</p>
            </div>`;
}
function renderTwoLineItem(esc, main, sub) {
    return `<div class="ts-wc-item">
                <span class="ts-wc-company">${esc(main)}</span>
                <span class="ts-wc-sep">·</span>
                <span class="ts-wc-sub">${esc(sub)}</span>
            </div>`;
}

// ── Mentor Tom Select (init before workcenter so onChange can reference it) ──
let tsMentor = null;
let getMentorOpts = null;

if (elMentor) {
    const currentMentor = elMentor.value;
    const mentorPH = elMentor.querySelector('option[value=""]')?.textContent.trim() ?? '';

    getMentorOpts = function(companyId) {
        const base = [{ value: '', text: mentorPH }];
        if (!companyId) return base;
        return base.concat(WORKERS_BY_COMPANY[companyId] ?? []);
    };

    const initialCompanyId = elWc?.querySelector(`option[value="${CSS.escape(elWc.value)}"]`)?.dataset.companyId ?? '';

    tsMentor = new TomSelect(elMentor, {
        options:          getMentorOpts(initialCompanyId),
        items:            currentMentor ? [currentMentor] : [],
        valueField:       'value',
        labelField:       'text',
        searchField:      ['text'],
        allowEmptyOption: true,
        create:           false,
        maxOptions:       null,
        placeholder:      mentorPH,
        wrapperClass:     'ts-wrapper ts-local',
        plugins:          ['clear_button'],
    });

    if (isAssignmentLocked) {
        tsMentor.disable();
    }

    if (elMentor.dataset.tsHasError) tsMentor.wrapper.classList.add('has-error');
}

// ── Workcenter Tom Select ─────────────────────────────────────────────────
if (elWc) {
    const currentWc = elWc.value;
    const wcPH = elWc.querySelector('option[value=""]')?.textContent.trim() ?? '';

    const wcOptions = [{ value: '', text: wcPH, company: '', company_id: '', name: '', city: '', search: '' }];
    elWc.querySelectorAll('option[data-company]').forEach(opt => {
        wcOptions.push({
            value:      opt.value,
            text:       opt.textContent.trim(),
            company:    opt.dataset.company ?? '',
            company_id: opt.dataset.companyId ?? '',
            name:       opt.textContent.trim(),
            city:       opt.dataset.city ?? '',
            search:     `${opt.dataset.company} ${opt.textContent.trim()} ${opt.dataset.city ?? ''}`,
        });
    });

    const tsWc = new TomSelect(elWc, {
        options:          wcOptions,
        items:            currentWc ? [currentWc] : [],
        valueField:       'value',
        labelField:       'text',
        searchField:      ['search'],
        allowEmptyOption: true,
        create:           false,
        maxOptions:       null,
        placeholder:      wcPH,
        wrapperClass:     'ts-wrapper ts-local',
        plugins:          ['clear_button'],
        render: {
            option: (d, esc) => {
                if (!d.company) return `<div class="py-0.5 text-gray-400 italic">${esc(d.text)}</div>`;
                const city = d.city ? ` <span class="ts-wc-city">· ${esc(d.city)}</span>` : '';
                return `<div class="ts-wc-option">
                            <p class="ts-wc-company">${esc(d.company)}</p>
                            <p class="ts-wc-sub">${esc(d.name)}${city}</p>
                        </div>`;
            },
            item: (d, esc) => {
                if (!d.company) return `<div>${esc(d.text)}</div>`;
                return renderTwoLineItem(esc, d.company, d.name);
            },
            no_results: () =>
                `<div class="no-results px-3 py-2 text-sm">{{ 'stays.position.field.workcenter_no_results'|trans({}, 'stays') }}</div>`,
        },
        onChange(value) {
            if (!tsMentor || !getMentorOpts) return;
            const companyId = value ? (tsWc.options[value]?.company_id ?? '') : '';
            const prevMentor = tsMentor.getValue();
            tsMentor.clearOptions();
            const newOpts = getMentorOpts(companyId);
            tsMentor.addOptions(newOpts);
            if (prevMentor && newOpts.some(o => o.value === prevMentor)) {
                tsMentor.setValue(prevMentor, true);
            } else {
                tsMentor.clear(true);
            }
        },
    });

    if (elWc.dataset.tsHasError) tsWc.wrapper.classList.add('has-error');
}

// ── Tutor docente Tom Select ──────────────────────────────────────────────
if (elTutor) {
    const currentTutor = elTutor.value;
    const tutorPH = elTutor.querySelector('option[value=""]')?.textContent.trim() ?? '';

    const tutorOpts = [{ value: '', text: tutorPH }];
    elTutor.querySelectorAll('option:not([value=""])').forEach(opt => {
        tutorOpts.push({ value: opt.value, text: opt.textContent.trim() });
    });

    const tsTutor = new TomSelect(elTutor, {
        options:          tutorOpts,
        items:            currentTutor ? [currentTutor] : [],
        valueField:       'value',
        labelField:       'text',
        searchField:      ['text'],
        allowEmptyOption: true,
        create:           false,
        maxOptions:       null,
        placeholder:      tutorPH,
        wrapperClass:     'ts-wrapper ts-local',
        plugins:          ['clear_button'],
    });

    if (isAssignmentLocked) {
        tsTutor.disable();
    }

    if (elTutor.dataset.tsHasError) tsTutor.wrapper.classList.add('has-error');
}

// ── Estado: helpers para radio buttons ───────────────────────────────────────
const stateRadios = Array.from(document.querySelectorAll('input[name="state"]'));
function getStateValue() {
    return stateRadios.find(r => r.checked)?.value ?? 'DRAFT';
}
function setStateValue(val) {
    const radio = stateRadios.find(r => r.value === val);
    if (radio && !radio.checked) {
        radio.checked = true;
        radio.dispatchEvent(new Event('change', { bubbles: true }));
    }
}

// ── Estado: PENDING/DONE bloqueados si faltan tutores ────────────────────────
(function () {
    const tutorEl  = document.getElementById('academic_tutor_id');
    const mentorEl = document.getElementById('workplace_mentor_id');
    const hint     = document.getElementById('state-tutors-hint');

    function syncStateOptions() {
        const locked = (tutorEl && tutorEl.value === '') || (mentorEl && mentorEl.value === '');

        stateRadios.forEach(radio => {
            if (radio.value !== 'DRAFT') radio.disabled = locked;
        });

        if (locked && getStateValue() !== 'DRAFT') setStateValue('DRAFT');
        if (hint) hint.classList.toggle('hidden', !locked);
    }

    if (tutorEl)  tutorEl.addEventListener('change', syncStateOptions);
    if (mentorEl) mentorEl.addEventListener('change', syncStateOptions);
    syncStateOptions();
}());

// ── Firmado: solo disponible en estado DONE ───────────────────────────────
(function () {
    const signedCb  = document.getElementById('signed-checkbox');
    const signedLbl = document.getElementById('signed-label');
    if (!signedCb) return;

    function syncSigned() {
        const isDone = getStateValue() === 'DONE';
        signedCb.disabled = !isDone;
        if (!isDone) signedCb.checked = false;
        signedLbl.classList.toggle('opacity-50', !isDone);
        signedLbl.classList.toggle('cursor-not-allowed', !isDone);
        signedLbl.classList.toggle('cursor-pointer', isDone);
        signedLbl.classList.toggle('hover:border-plum-200', isDone);
        signedLbl.classList.toggle('hover:bg-plum-50/40', isDone);
    }

    stateRadios.forEach(r => r.addEventListener('change', syncSigned));
    syncSigned();
}());

// ── Estudiante Tom Select ─────────────────────────────────────────────────
if (elStudent) {
    const currentStudent = elStudent.value;
    const studentPH = elStudent.querySelector('option[value=""]')?.textContent.trim() ?? '';

    const studentOpts = [{ value: '', text: studentPH }];
    elStudent.querySelectorAll('option:not([value=""])').forEach(opt => {
        studentOpts.push({
            value:    opt.value,
            text:     opt.textContent.trim(),
            group:    opt.dataset.group ?? '',
            nie:      opt.dataset.nie   ?? '',
            search:   `${opt.textContent.trim()} ${opt.dataset.nie ?? ''} ${opt.dataset.group ?? ''}`,
            disabled: opt.dataset.disabled === '1',
        });
    });

    const tsStudent = new TomSelect(elStudent, {
        options:          studentOpts,
        items:            currentStudent ? [currentStudent] : [],
        valueField:       'value',
        labelField:       'text',
        searchField:      ['search'],
        disabledField:    'disabled',
        allowEmptyOption: true,
        create:           false,
        maxOptions:       null,
        placeholder:      studentPH,
        wrapperClass:     'ts-wrapper ts-local',
        plugins:          ['clear_button'],
        render: {
            option: (d, esc) => {
                if (!d.value) return `<div class="py-0.5 text-gray-400 italic">${esc(d.text)}</div>`;
                const sub = [d.nie, d.group].filter(Boolean).join(' · ');
                return sub
                    ? renderTwoLineOption(esc, d.text, sub)
                    : `<div class="py-0.5">${esc(d.text)}</div>`;
            },
            item: (d, esc) => {
                if (!d.value) return `<div>${esc(d.text)}</div>`;
                return d.group
                    ? renderTwoLineItem(esc, d.text, d.group)
                    : `<div>${esc(d.text)}</div>`;
            },
        },
    });

    if (isAssignmentLocked) {
        tsStudent.disable();
    }
}
</script>
{% endblock %}
