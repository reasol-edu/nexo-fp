{% extends 'email/_layout.html.twig' %}

{% block content %}
<p style="margin: 0 0 16px;">
    {{ 'emails.greeting'|trans({'%name%': teacher.name.firstName}, 'emails') }}
</p>
<p style="margin: 0 0 24px;">
    {{ 'emails.email_verification.intro'|trans({}, 'emails') }}
</p>
<p style="margin: 0 0 24px; text-align: center;">
    <a href="{{ verify_url }}"
       style="display: inline-block; background-color: #6d28d9; color: #ffffff; font-size: 14px;
              font-weight: 600; padding: 12px 24px; border-radius: 8px; text-decoration: none;">
        {{ 'emails.email_verification.cta'|trans({}, 'emails') }}
    </a>
</p>
<p style="margin: 0; color: #6b7280; font-size: 13px;">
    {{ 'emails.email_verification.expiry_notice'|trans({}, 'emails') }}
</p>
{% endblock %}
