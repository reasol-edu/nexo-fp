{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'company.new.title'|trans({}, 'companies') }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-3xl mx-auto space-y-8">

    {# Breadcrumb #}
    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
            <a href="{{ path('app_companies_index') }}" class="hover:text-plum-600 transition-colors">
                {{ 'companies.title'|trans({}, 'companies') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'company.new.title'|trans({}, 'companies') }}</h1>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <form method="post" class="px-6 py-6 space-y-5">
            <input type="hidden" name="_token" value="{{ csrf_token('new_company') }}">

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">

                {# Nombre #}
                <div class="sm:col-span-2">
                    <twig:Form:Field
                        id="name"
                        name="name"
                        label="{{ 'company.field.name'|trans({}, 'companies') }}"
                        value="{{ values.name }}"
                        :error="errors.name ?? null"
                    />
                </div>

                {# CIF/NIF #}
                <div>
                    <twig:Form:Field
                        id="vat_number"
                        name="vat_number"
                        label="{{ 'company.field.vat_number'|trans({}, 'companies') }}"
                        value="{{ values.vat_number }}"
                        :error="errors.vat_number ?? null"
                        :mono="true"
                    />
                </div>

                {# Localidad #}
                <div class="sm:col-span-3">
                    <twig:Form:Field
                        id="city"
                        name="city"
                        label="{{ 'company.field.city'|trans({}, 'companies') }}"
                        value="{{ values.city }}"
                        :error="errors.city ?? null"
                    />
                </div>

            </div>

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_companies_index') }}"
                   class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm font-medium text-gray-700
                          hover:bg-gray-50 transition-colors">
                    {{ 'company.cancel'|trans({}, 'companies') }}
                </a>
                <button type="submit"
                        class="rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                               hover:bg-plum-700 transition-colors shadow-xs">
                    {{ 'company.save'|trans({}, 'companies') }}
                </button>
            </div>
        </form>
    </div>

</div>
{% endblock %}
