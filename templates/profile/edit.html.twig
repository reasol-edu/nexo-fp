{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'profile.title'|trans({}, 'messages') }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto space-y-8">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
            <a href="{{ path('app_dashboard') }}" class="hover:text-plum-600 transition-colors">
                {{ 'dashboard'|trans({}, 'navigation') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'profile.title'|trans({}, 'messages') }}</h1>
    </div>

    {# ── Tabs ─────────────────────────────────────────────────────────────── #}
    <div class="flex gap-1 rounded-xl bg-gray-100 p-1">
        <a href="{{ path('app_profile') }}"
           class="flex-1 rounded-lg bg-white py-2 text-center text-sm font-medium shadow-xs
                  text-gray-900 transition-colors">
            {{ 'profile.tab.personal'|trans({}, 'messages') }}
        </a>
        <a href="{{ path('app_profile_settings') }}"
           class="flex-1 rounded-lg py-2 text-center text-sm font-medium transition-colors
                  text-gray-600 hover:text-gray-900">
            {{ 'settings.title'|trans({}, 'settings') }}
        </a>
    </div>

    {# ── Datos personales ─────────────────────────────────────────────────────── #}
    <form method="post" class="space-y-8">
        <input type="hidden" name="_token" value="{{ csrf_token('edit_profile') }}">

        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">{{ 'profile.section.personal'|trans({}, 'messages') }}</h2>
            </div>
            <div class="px-6 py-6 space-y-5">

                {# Nombre y apellidos #}
                <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                    <div>
                        <label for="first_name" class="block text-sm font-medium text-gray-700 mb-1.5">
                            {{ 'profile.field.first_name'|trans({}, 'messages') }}
                        </label>
                        <input id="first_name" type="text" name="first_name"
                               value="{{ values.first_name }}"
                               class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                      transition-colors focus:outline-none focus:ring-3
                                      {{ errors.first_name is defined
                                          ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                          : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                        {% if errors.first_name is defined %}
                            <p class="mt-1.5 text-xs text-red-600">{{ errors.first_name }}</p>
                        {% endif %}
                    </div>

                    <div>
                        <label for="last_name" class="block text-sm font-medium text-gray-700 mb-1.5">
                            {{ 'profile.field.last_name'|trans({}, 'messages') }}
                        </label>
                        <input id="last_name" type="text" name="last_name"
                               value="{{ values.last_name }}"
                               class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                      transition-colors focus:outline-none focus:ring-3
                                      {{ errors.last_name is defined
                                          ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                          : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                        {% if errors.last_name is defined %}
                            <p class="mt-1.5 text-xs text-red-600">{{ errors.last_name }}</p>
                        {% endif %}
                    </div>
                </div>

                {# Usuario (solo lectura) #}
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'profile.field.username'|trans({}, 'messages') }}
                    </label>
                    <div class="flex items-center gap-3">
                        <input type="text" readonly value="{{ teacher.username }}"
                               class="block w-full rounded-xl border border-gray-200 bg-gray-100 py-2.5 px-3.5
                                      text-sm font-mono text-gray-500 cursor-not-allowed">
                        {% if teacher.isExternal() %}
                            <span class="shrink-0 inline-flex items-center gap-1.5 rounded-lg bg-blue-50 border border-blue-200
                                         px-3 py-1.5 text-xs font-medium text-blue-700">
                                {{ ux_icon('heroicons:link', {class: 'h-3.5 w-3.5'}) }}
                                {{ 'profile.badge.external'|trans({}, 'messages') }}
                            </span>
                        {% endif %}
                    </div>
                    <p class="mt-1.5 text-xs text-gray-400">{{ 'profile.field.username_help'|trans({}, 'messages') }}</p>
                </div>

                {# Email #}
                <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'profile.field.email'|trans({}, 'messages') }}
                    </label>
                    <input id="email" type="email" name="email"
                           value="{{ values.email }}"
                           class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                  transition-colors focus:outline-none focus:ring-3
                                  {{ errors.email is defined
                                      ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                      : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                    {% if errors.email is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.email }}</p>
                    {% endif %}
                </div>

            </div>
        </div>

        {# ── Contraseña ───────────────────────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-base font-semibold text-gray-900">{{ 'profile.section.password'|trans({}, 'messages') }}</h2>
            </div>

            {% if teacher.isExternal() %}
                <div class="px-6 py-6">
                    <div class="flex items-start gap-3 rounded-xl border border-blue-200 bg-blue-50 px-4 py-3.5 text-sm text-blue-800">
                        {{ ux_icon('heroicons:information-circle', {class: 'h-5 w-5 shrink-0 text-blue-500 mt-0.5'}) }}
                        <p>{{ 'profile.password.external_notice'|trans({}, 'messages') }}</p>
                    </div>
                </div>
            {% else %}
                <div class="px-6 py-6 space-y-5">

                    {# Contraseña actual #}
                    <div>
                        <label for="current_password" class="block text-sm font-medium text-gray-700 mb-1.5">
                            {{ 'profile.field.current_password'|trans({}, 'messages') }}
                        </label>
                        <input id="current_password" type="password" name="current_password"
                               autocomplete="current-password"
                               class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                      transition-colors focus:outline-none focus:ring-3
                                      {{ errors.current_password is defined
                                          ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                          : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                        {% if errors.current_password is defined %}
                            <p class="mt-1.5 text-xs text-red-600">{{ errors.current_password }}</p>
                        {% endif %}
                    </div>

                    {# Nueva contraseña #}
                    <div>
                        <label for="new_password" class="block text-sm font-medium text-gray-700 mb-1.5">
                            {{ 'profile.field.new_password'|trans({}, 'messages') }}
                        </label>
                        <input id="new_password" type="password" name="new_password"
                               autocomplete="new-password"
                               placeholder="{{ 'profile.field.new_password_help'|trans({}, 'messages') }}"
                               class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                      transition-colors focus:outline-none focus:ring-3
                                      {{ errors.new_password is defined
                                          ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                          : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                        {% if errors.new_password is defined %}
                            <p class="mt-1.5 text-xs text-red-600">{{ errors.new_password }}</p>
                        {% endif %}
                    </div>

                    {# Confirmar nueva contraseña #}
                    <div>
                        <label for="new_password_confirm" class="block text-sm font-medium text-gray-700 mb-1.5">
                            {{ 'profile.field.new_password_confirm'|trans({}, 'messages') }}
                        </label>
                        <input id="new_password_confirm" type="password" name="new_password_confirm"
                               autocomplete="new-password"
                               class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                      transition-colors focus:outline-none focus:ring-3
                                      {{ errors.new_password_confirm is defined
                                          ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                          : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                        {% if errors.new_password_confirm is defined %}
                            <p class="mt-1.5 text-xs text-red-600">{{ errors.new_password_confirm }}</p>
                        {% endif %}
                    </div>

                </div>
            {% endif %}
        </div>

        {# ── Botón guardar ─────────────────────────────────────────────────────── #}
        <div class="flex justify-end">
            <button type="submit"
                    class="rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                           hover:bg-plum-700 transition-colors shadow-xs">
                {{ 'profile.save'|trans({}, 'messages') }}
            </button>
        </div>

    </form>

</div>
{% endblock %}
