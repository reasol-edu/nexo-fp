{% extends 'base.html.twig' %}

{% block title %}{{ 'page_title'|trans({}, 'login') }}{% endblock %}

{% block body %}
<div class="min-h-screen flex">

    {# ── Panel izquierdo: marca ─────────────────────────────────────────────── #}
    <div class="hidden lg:flex lg:w-5/12 xl:w-2/5 relative overflow-hidden flex-col
                bg-gradient-to-br from-plum-950 via-plum-900 to-plum-800">

        {# Círculos decorativos #}
        <div class="absolute -top-32 -right-32 w-[28rem] h-[28rem] rounded-full bg-white/5"></div>
        <div class="absolute top-1/2 -right-16 w-64 h-64 rounded-full bg-plum-600/30"></div>
        <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full bg-white/5"></div>
        <div class="absolute bottom-1/3 right-8 w-32 h-32 rounded-full bg-plum-500/20"></div>

        <div class="relative flex flex-col justify-between h-full p-12 z-10">
            {# Logo #}
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-white/15 backdrop-blur flex items-center justify-center ring-1 ring-white/20">
                    <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-1.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
                    </svg>
                </div>
                <span class="text-white text-xl font-semibold tracking-tight">{{ app_name }}{% if app_version %} - v{{ app_version }}{% endif %}</span>
            </div>

            {# Texto central #}
            <div>
                <p class="text-plum-300 text-sm font-medium uppercase tracking-widest mb-4">{{ 'platform_label'|trans({}, 'login') }}</p>
                <h1 class="text-4xl font-bold text-white leading-tight mb-4">
                    {{ app_name }}{% if app_version %} - v{{ app_version }}{% endif %}
                </h1>
                <p class="text-plum-300 text-lg leading-relaxed">
                    {{ 'hero_description'|trans({}, 'login') }}
                </p>
            </div>

            {# Footer #}
            <p class="text-plum-500 text-sm">{{ 'copyright'|trans({'%year%': 'now'|date('Y')}, 'login') }}</p>
        </div>
    </div>

    {# ── Panel derecho: formulario ──────────────────────────────────────────── #}
    <div class="flex-1 flex items-center justify-center p-8 bg-white">
        <div class="w-full max-w-md">

            {# Logo móvil #}
            <div class="flex items-center gap-2 mb-10 lg:hidden">
                <div class="w-8 h-8 rounded-lg bg-plum-600 flex items-center justify-center">
                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-1.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
                    </svg>
                </div>
                <span class="text-plum-900 text-lg font-semibold">{{ app_name }}</span>
            </div>

            {# Encabezado #}
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-gray-900 mb-1">{{ 'welcome_title'|trans({}, 'login') }}</h2>
                <p class="text-gray-500">{{ 'welcome_subtitle'|trans({}, 'login') }}</p>
            </div>

            {# Error #}
            {% if error %}
                <div class="flex items-start gap-3 bg-red-50 border border-red-100 text-red-700 rounded-xl px-4 py-3 mb-6 text-sm">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
                    </svg>
                    <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            {# Formulario #}
            <form method="post" novalidate class="space-y-5">

                {# Usuario #}
                <div>
                    <label for="username" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'username_label'|trans({}, 'login') }}
                    </label>
                    <div class="relative">
                        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                            <svg class="w-4.5 h-4.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                            </svg>
                        </div>
                        <input id="username"
                               type="text"
                               name="_username"
                               value="{{ last_username }}"
                               autocomplete="username"
                               autofocus
                               required
                               class="block w-full rounded-xl border border-gray-200 bg-gray-50 py-3 pl-10 pr-4
                                      text-gray-900 placeholder-gray-400 text-sm
                                      transition-all duration-150
                                      focus:border-plum-500 focus:bg-white focus:ring-3 focus:ring-plum-500/20 focus:outline-none">
                    </div>
                </div>

                {# Contraseña con toggle #}
                <div data-controller="password-visibility">
                    <div class="flex items-center justify-between mb-1.5">
                        <label for="password" class="block text-sm font-medium text-gray-700">
                            {{ 'password_label'|trans({}, 'login') }}
                        </label>
                    </div>
                    <div class="relative">
                        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                            <svg class="w-4.5 h-4.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/>
                            </svg>
                        </div>
                        <input id="password"
                               type="password"
                               name="_password"
                               autocomplete="current-password"
                               required
                               data-password-visibility-target="input"
                               class="block w-full rounded-xl border border-gray-200 bg-gray-50 py-3 pl-10 pr-11
                                      text-gray-900 placeholder-gray-400 text-sm
                                      transition-all duration-150
                                      focus:border-plum-500 focus:bg-white focus:ring-3 focus:ring-plum-500/20 focus:outline-none">
                        <button type="button"
                                data-action="password-visibility#toggle"
                                class="absolute inset-y-0 right-0 flex items-center pr-3.5 text-gray-400 hover:text-gray-600 transition-colors">
                            {# Ojo abierto (contraseña oculta) #}
                            <svg data-password-visibility-target="eyeOpen"
                                 class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/>
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                            </svg>
                            {# Ojo tachado (contraseña visible) #}
                            <svg data-password-visibility-target="eyeClosed"
                                 class="w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# Botón #}
                <button type="submit"
                        class="w-full flex items-center justify-center gap-2
                               bg-plum-600 hover:bg-plum-700 active:bg-plum-800
                               text-white font-semibold text-sm
                               py-3 px-4 rounded-xl
                               transition-colors duration-150
                               focus:outline-none focus:ring-3 focus:ring-plum-500/40">
                    {{ 'submit'|trans({}, 'login') }}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                    </svg>
                </button>
            </form>
        </div>
    </div>

</div>
{% endblock %}
