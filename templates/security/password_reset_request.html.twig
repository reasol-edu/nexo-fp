{% extends 'base.html.twig' %}

{% block title %}{{ 'password_reset.page_title.request'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="min-h-screen flex">

    {# ── Panel izquierdo: marca ─────────────────────────────────────────────── #}
    <div class="hidden lg:flex lg:w-5/12 xl:w-2/5 relative overflow-hidden flex-col
                bg-gradient-to-br from-plum-950 via-plum-900 to-plum-800">
        <div class="absolute -top-32 -right-32 w-[28rem] h-[28rem] rounded-full bg-white/5"></div>
        <div class="absolute top-1/2 -right-16 w-64 h-64 rounded-full bg-plum-600/30"></div>
        <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full bg-white/5"></div>
        <div class="absolute bottom-1/3 right-8 w-32 h-32 rounded-full bg-plum-500/20"></div>
        <div class="relative flex flex-col justify-between h-full p-12 z-10">
            <div class="flex items-start gap-4">
                <img src="{{ asset('static/logo.svg') }}" alt="{{ app_name }}" class="w-40 h-40 shrink-0">
                <span class="text-white/60 text-xs font-medium tracking-tight mt-1">{% if app_version %}v{{ app_version }}{% endif %}</span>
            </div>
            <div>
                <p class="text-plum-300 text-sm font-medium uppercase tracking-widest mb-4">{{ 'platform_label'|trans({}, 'login') }}</p>
                <h1 class="text-4xl font-bold text-white leading-tight mb-4">{{ app_name }}</h1>
                <p class="text-plum-300 text-lg leading-relaxed">{{ 'hero_description'|trans({}, 'login') }}</p>
            </div>
            <p class="text-plum-500 text-sm">{{ 'copyright'|trans({'%year%': 'now'|date('Y')}, 'login') }} REASOL, Luis Ramón López López</p>
        </div>
    </div>

    {# ── Panel derecho: formulario ──────────────────────────────────────────── #}
    <div class="flex-1 flex items-center justify-center p-8 bg-white">
        <div class="w-full max-w-md">

            {# Logo móvil #}
            <div class="flex items-center gap-2 mb-10 lg:hidden">
                <img src="{{ asset('static/logo.svg') }}" alt="{{ app_name }}" class="w-14 h-14 shrink-0">
                <span class="text-plum-900 text-lg font-semibold">{{ app_name }}</span>
            </div>

            {% if sent %}
                {# ── Estado: enlace enviado ──────────────────────────────────── #}
                <div class="flex items-start gap-3 bg-green-50 border border-green-200 text-green-800 rounded-xl px-4 py-4 mb-6">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                    </svg>
                    <div>
                        <p class="font-semibold text-sm">{{ 'password_reset.request.sent_title'|trans({}, 'messages') }}</p>
                        <p class="text-sm mt-1">{{ 'password_reset.request.sent_body'|trans({}, 'messages') }}</p>
                    </div>
                </div>
            {% else %}
                {# ── Encabezado ──────────────────────────────────────────────── #}
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-gray-900 mb-1">{{ 'password_reset.page_title.request'|trans({}, 'messages') }}</h2>
                    <p class="text-gray-500 text-sm leading-relaxed">{{ 'password_reset.request.intro'|trans({}, 'messages') }}</p>
                </div>

                {# ── Error ───────────────────────────────────────────────────── #}
                {% if error %}
                    <div class="flex items-start gap-3 bg-red-50 border border-red-100 text-red-700 rounded-xl px-4 py-3 mb-6 text-sm">
                        <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
                        </svg>
                        <span>{{ error }}</span>
                    </div>
                {% endif %}

                {# ── Formulario ──────────────────────────────────────────────── #}
                <form method="post" novalidate class="space-y-5">
                    <div>
                        <label for="username" class="block text-sm font-medium text-gray-700 mb-1.5">
                            {{ 'password_reset.request.username_label'|trans({}, 'messages') }}
                        </label>
                        <div class="relative">
                            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                                <svg class="w-4.5 h-4.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                                </svg>
                            </div>
                            <input id="username" type="text" name="username"
                                   autocomplete="username" autofocus required
                                   class="block w-full rounded-xl border border-gray-200 bg-gray-50 py-3 pl-10 pr-4
                                          text-gray-900 placeholder-gray-400 text-sm transition-all duration-150
                                          focus:border-plum-500 focus:bg-white focus:ring-3 focus:ring-plum-500/20 focus:outline-none">
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('password_reset_request') }}">

                    <button type="submit"
                            class="w-full flex items-center justify-center gap-2
                                   bg-plum-600 hover:bg-plum-700 active:bg-plum-800
                                   text-white font-semibold text-sm
                                   py-3 px-4 rounded-xl transition-colors duration-150
                                   focus:outline-none focus:ring-3 focus:ring-plum-500/40">
                        {{ 'password_reset.request.submit'|trans({}, 'messages') }}
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                        </svg>
                    </button>
                </form>
            {% endif %}

            {# ── Volver al login ─────────────────────────────────────────────── #}
            <p class="mt-6 text-center text-sm text-gray-500">
                <a href="{{ path('app_login') }}"
                   class="font-medium text-plum-600 hover:text-plum-800 transition-colors">
                    &larr; {{ 'password_reset.request.back_to_login'|trans({}, 'messages') }}
                </a>
            </p>

        </div>
    </div>

</div>
{% endblock %}
