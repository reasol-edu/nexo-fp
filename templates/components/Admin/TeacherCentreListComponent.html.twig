<div {{ attributes }}>
    {% if centre.activeAcademicYear is null %}
        <div class="px-6 py-16 text-center">
            {{ ux_icon('heroicons:exclamation-circle', {class: 'mx-auto h-10 w-10 text-amber-300 mb-3'}) }}
            <p class="text-sm text-gray-500">{{ 'centre_teachers.no_active_year'|trans({}, 'admin') }}</p>
        </div>
    {% else %}
        {% set pagination = this.pagination %}

        {# Barra de búsqueda #}
        <div class="px-6 py-3 border-b border-gray-100 bg-gray-50/50">
            <div class="relative max-w-xs">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                    {{ ux_icon('heroicons:magnifying-glass', {class: 'h-4 w-4 text-gray-400'}) }}
                </div>
                <input type="search"
                       data-model="norender|search"
                       data-action="input->live#action"
                       data-live-action-param="resetPage"
                       placeholder="{{ 'centre_teachers.search'|trans({}, 'admin') }}"
                       value="{{ search }}"
                       class="block w-full rounded-lg border border-gray-200 bg-white py-2 pl-9 pr-3 text-sm
                              text-gray-900 placeholder-gray-400 focus:border-plum-500 focus:outline-none
                              focus:ring-3 focus:ring-plum-500/20 transition-colors">
            </div>
        </div>

        {% if pagination.totalItems == 0 %}
            <div class="px-6 py-16 text-center">
                {{ ux_icon('heroicons:user-group', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
                <p class="text-sm text-gray-500">
                    {{ (search is not empty ? 'centre_teachers.search_empty' : 'centre_teachers.empty')|trans({}, 'admin') }}
                </p>
            </div>
        {% else %}
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100 bg-gray-50">
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'centre_teachers.col.name'|trans({}, 'admin') }}</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">{{ 'centre_teachers.col.username'|trans({}, 'admin') }}</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">{{ 'centre_teachers.col.email'|trans({}, 'admin') }}</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">{{ 'centre_teachers.col.roles'|trans({}, 'admin') }}</th>
                        <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'centre_teachers.col.actions'|trans({}, 'admin') }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for teacher in pagination.items %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                <span class="font-medium text-gray-900">{{ teacher.name.lastName }}, {{ teacher.name.firstName }}</span>
                            </td>
                            <td class="px-6 py-4 font-mono text-xs text-gray-600 hidden sm:table-cell">{{ teacher.username }}</td>
                            <td class="px-6 py-4 text-xs text-gray-500 hidden md:table-cell">{{ teacher.email ?? '—' }}</td>
                            <td class="px-6 py-4 hidden lg:table-cell">
                                <div class="flex items-center gap-1.5 flex-wrap">
                                    {% if teacher.admin %}
                                        <span class="inline-flex items-center rounded-full bg-plum-50 px-2 py-0.5 text-xs font-medium text-plum-700 ring-1 ring-inset ring-plum-600/20">
                                            {{ 'teachers.badge.admin'|trans({}, 'admin') }}
                                        </span>
                                    {% endif %}
                                    {% if not teacher.active %}
                                        <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/20">
                                            {{ 'teachers.badge.inactive'|trans({}, 'admin') }}
                                        </span>
                                    {% endif %}
                                    {% if teacher.external %}
                                        <span class="inline-flex items-center rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20">
                                            {{ 'teachers.badge.external'|trans({}, 'admin') }}
                                        </span>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="{{ path('app_admin_teachers_edit', {id: teacher.id}) }}"
                                       class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-medium
                                              text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                        {{ ux_icon('heroicons:pencil-square', {class: 'h-3.5 w-3.5'}) }}
                                        {{ 'teachers.edit'|trans({}, 'admin') }}
                                    </a>
                                    <form method="post"
                                          action="{{ path('app_admin_centre_teachers_remove', {centreId: centre.id, teacherId: teacher.id}) }}"
                                          onsubmit="return confirm('{{ 'centre_teachers.remove_confirm'|trans({}, 'admin') }}')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('remove_centre_teacher_' ~ teacher.id) }}">
                                        <button type="submit"
                                                class="inline-flex items-center gap-1.5 rounded-lg border border-red-200 px-3 py-1.5 text-xs font-medium
                                                       text-red-600 hover:bg-red-50 hover:border-red-300 transition-colors">
                                            {{ ux_icon('heroicons:user-minus', {class: 'h-3.5 w-3.5'}) }}
                                            {{ 'centre_teachers.action.remove'|trans({}, 'admin') }}
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>

            {% if pagination.totalPages > 1 %}
                <div class="flex items-center justify-between border-t border-gray-100 px-6 py-3 gap-4 flex-wrap">
                    <p class="text-xs text-gray-500 shrink-0">
                        {{ 'pagination.summary'|trans({'%from%': pagination.firstItemIndex, '%to%': pagination.lastItemIndex, '%total%': pagination.totalItems}) }}
                    </p>
                    <nav class="flex items-center gap-1">
                        {% if pagination.hasPreviousPage %}
                            <button data-action="live#action" data-live-action-param="setPage" data-live-page-param="{{ pagination.previousPage }}"
                                    class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-200 text-gray-500 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                {{ ux_icon('heroicons:chevron-left', {class: 'h-4 w-4'}) }}
                            </button>
                        {% else %}
                            <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-100 text-gray-300 cursor-not-allowed">
                                {{ ux_icon('heroicons:chevron-left', {class: 'h-4 w-4'}) }}
                            </span>
                        {% endif %}
                        {% for p in pagination.pageRange %}
                            {% if p is null %}
                                <span class="inline-flex items-center justify-center h-8 px-1 text-xs text-gray-400 select-none">…</span>
                            {% elseif p == pagination.currentPage %}
                                <span class="inline-flex items-center justify-center h-8 min-w-8 px-2 rounded-lg bg-plum-600 text-white text-xs font-semibold">{{ p }}</span>
                            {% else %}
                                <button data-action="live#action" data-live-action-param="setPage" data-live-page-param="{{ p }}"
                                        class="inline-flex items-center justify-center h-8 min-w-8 px-2 rounded-lg border border-gray-200 text-gray-600 text-xs hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                    {{ p }}
                                </button>
                            {% endif %}
                        {% endfor %}
                        {% if pagination.hasNextPage %}
                            <button data-action="live#action" data-live-action-param="setPage" data-live-page-param="{{ pagination.nextPage }}"
                                    class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-200 text-gray-500 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
                            </button>
                        {% else %}
                            <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-100 text-gray-300 cursor-not-allowed">
                                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
                            </span>
                        {% endif %}
                    </nav>
                </div>
            {% endif %}
        {% endif %}
    {% endif %}
</div>
