<div {{ attributes }}>
    {% set pagination = this.pagination %}

    {# Barra de búsqueda #}
    <div class="px-6 py-3 border-b border-gray-100 bg-gray-50/50 flex items-center gap-3">
        <div class="relative flex-1 max-w-xs">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                {{ ux_icon('heroicons:magnifying-glass', {class: 'h-4 w-4 text-gray-400'}) }}
            </div>
            <input type="search"
                   data-model="search"
                   placeholder="{{ 'centres.search'|trans({}, 'admin') }}"
                   value="{{ search }}"
                   class="block w-full rounded-lg border border-gray-200 bg-white py-2 pl-9 pr-3 text-sm
                          text-gray-900 placeholder-gray-400 focus:border-plum-500 focus:outline-none
                          focus:ring-3 focus:ring-plum-500/20 transition-colors">
        </div>
        <svg data-loading class="hidden h-4 w-4 text-plum-500 animate-spin shrink-0 ml-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
        </svg>
    </div>

    <div data-loading="addClass(opacity-50 pointer-events-none)" class="transition-opacity">
    {% if pagination.totalItems == 0 %}
        <div class="px-6 py-16 text-center">
            {{ ux_icon('heroicons:building-library', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
            <p class="text-sm text-gray-500">
                {% if search is not empty %}
                    {{ 'centres.search_empty'|trans({}, 'admin') }}
                {% else %}
                    {{ 'centres.empty'|trans({}, 'admin') }}
                {% endif %}
            </p>
        </div>
    {% else %}
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-100 bg-gray-50">
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'centres.code'|trans({}, 'admin') }}</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'centres.name'|trans({}, 'admin') }}</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'centres.city'|trans({}, 'admin') }}</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'centres.active_year'|trans({}, 'admin') }}</th>
                    <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'centres.actions'|trans({}, 'admin') }}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for centre in pagination.items %}
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 font-mono text-xs text-gray-500">{{ centre.code }}</td>
                        <td class="px-6 py-4 font-medium text-gray-900">{{ centre.name }}</td>
                        <td class="px-6 py-4 text-gray-600">{{ centre.city }}</td>
                        <td class="px-6 py-4">
                            {% if centre.activeAcademicYear %}
                                <span class="inline-flex items-center rounded-full bg-green-50 px-2.5 py-0.5 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">
                                    {{ centre.activeAcademicYear.name }}
                                </span>
                            {% else %}
                                <span class="text-gray-400 text-xs">{{ 'centres.no_active_year'|trans({}, 'admin') }}</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center justify-end gap-2">
                                <a href="{{ path('app_admin_centres_edit', {id: centre.id}) }}"
                                   class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-medium
                                          text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                    {{ ux_icon('heroicons:pencil-square', {class: 'h-3.5 w-3.5'}) }}
                                    {{ 'centres.edit'|trans({}, 'admin') }}
                                </a>
                                <form method="post"
                                      action="{{ path('app_admin_centres_delete', {id: centre.id}) }}"
                                      onsubmit="return confirm('{{ 'centres.delete_confirm'|trans({}, 'admin') }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_centre_' ~ centre.id) }}">
                                    <button type="submit"
                                            class="inline-flex items-center gap-1.5 rounded-lg border border-red-200 px-3 py-1.5 text-xs font-medium
                                                   text-red-600 hover:bg-red-50 hover:border-red-300 transition-colors">
                                        {{ ux_icon('heroicons:trash', {class: 'h-3.5 w-3.5'}) }}
                                        {{ 'centres.delete'|trans({}, 'admin') }}
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {% if pagination.totalPages > 1 %}
            <div class="flex items-center justify-between border-t border-gray-100 px-6 py-3 gap-4 flex-wrap">
                <p class="text-xs text-gray-500 shrink-0">
                    {{ 'pagination.summary'|trans({'%from%': pagination.firstItemIndex, '%to%': pagination.lastItemIndex, '%total%': pagination.totalItems}) }}
                </p>
                <nav class="flex items-center gap-1">
                    {% if pagination.hasPreviousPage %}
                        <button data-action="live#action" data-live-action-param="setPage" data-live-page-param="{{ pagination.previousPage }}"
                                class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-200 text-gray-500 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                            {{ ux_icon('heroicons:chevron-left', {class: 'h-4 w-4'}) }}
                        </button>
                    {% else %}
                        <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-100 text-gray-300 cursor-not-allowed">
                            {{ ux_icon('heroicons:chevron-left', {class: 'h-4 w-4'}) }}
                        </span>
                    {% endif %}
                    {% for p in pagination.pageRange %}
                        {% if p is null %}
                            <span class="inline-flex items-center justify-center h-8 px-1 text-xs text-gray-400 select-none">…</span>
                        {% elseif p == pagination.currentPage %}
                            <span class="inline-flex items-center justify-center h-8 min-w-8 px-2 rounded-lg bg-plum-600 text-white text-xs font-semibold">{{ p }}</span>
                        {% else %}
                            <button data-action="live#action" data-live-action-param="setPage" data-live-page-param="{{ p }}"
                                    class="inline-flex items-center justify-center h-8 min-w-8 px-2 rounded-lg border border-gray-200 text-gray-600 text-xs hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                {{ p }}
                            </button>
                        {% endif %}
                    {% endfor %}
                    {% if pagination.hasNextPage %}
                        <button data-action="live#action" data-live-action-param="setPage" data-live-page-param="{{ pagination.nextPage }}"
                                class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-200 text-gray-500 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
                        </button>
                    {% else %}
                        <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-100 text-gray-300 cursor-not-allowed">
                            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
                        </span>
                    {% endif %}
                </nav>
            </div>
        {% endif %}
    {% endif %}
    </div>
</div>
