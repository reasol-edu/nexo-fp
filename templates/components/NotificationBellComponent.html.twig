<div {{ attributes.defaults({class: 'relative'}).defaults(stimulus_controller('dropdown')) }}>

    {% set total = this.total %}

    <button type="button"
            data-action="dropdown#toggle"
            aria-label="{{ 'bell.aria'|trans({}, 'notifications') }}"
            class="relative rounded-lg p-1.5 text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors">
        {{ ux_icon('heroicons:bell', {class: 'h-5 w-5'}) }}
        {% if total > 0 %}
            <span class="absolute -top-0.5 -right-0.5 flex h-4 min-w-4 items-center justify-center
                         rounded-full bg-red-500 px-1 text-[10px] font-semibold text-white leading-none">
                {{ total > 9 ? '9+' : total }}
            </span>
        {% endif %}
    </button>

    <div data-dropdown-target="menu"
         class="hidden absolute right-0 z-40 mt-2 w-80 origin-top-right rounded-xl border border-gray-200
                bg-white shadow-lg overflow-hidden">

        <div class="border-b border-gray-100 px-4 py-2.5">
            <p class="text-xs font-semibold text-gray-700 uppercase tracking-wide">
                {{ 'bell.title'|trans({}, 'notifications') }}
            </p>
        </div>

        {% if total == 0 %}
            <div class="px-4 py-8 text-center">
                {{ ux_icon('heroicons:check-circle', {class: 'mx-auto h-8 w-8 text-green-300 mb-2'}) }}
                <p class="text-sm text-gray-500">{{ 'bell.empty'|trans({}, 'notifications') }}</p>
            </div>
        {% else %}
            <ul class="max-h-96 divide-y divide-gray-50 overflow-y-auto">
                {% for item in this.visibleItems %}
                    <li>
                        <a href="{{ path('app_stays_show', {id: item.stay.id.toRfc4122}) }}"
                           class="flex items-start gap-3 px-4 py-3 hover:bg-gray-50 transition-colors">
                            {% set icon = {
                                signature_due:             'heroicons:pencil-square',
                                free_positions:            'heroicons:user-plus',
                                missing_tutor:             'heroicons:academic-cap',
                                missing_mentor:            'heroicons:briefcase',
                                students_without_position: 'heroicons:user-group',
                            }[item.type] %}
                            <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-lg
                                         {{ item.type == 'signature_due' ? 'bg-amber-100 text-amber-600' : 'bg-plum-100 text-plum-600' }}">
                                {{ ux_icon(icon, {class: 'h-4 w-4'}) }}
                            </span>
                            <span class="min-w-0">
                                <span class="block truncate text-sm font-medium text-gray-900">{{ item.stay.name }}</span>
                                <span class="block text-xs text-gray-500">
                                    {{ ('item.' ~ item.type)|trans({'%count%': item.count}, 'notifications') }}
                                </span>
                            </span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
            {% if total > constant('App\\Twig\\Components\\NotificationBellComponent::MAX_ITEMS') %}
                <div class="border-t border-gray-100 px-4 py-2 text-center">
                    <a href="{{ path('app_dashboard') }}" class="text-xs font-medium text-plum-600 hover:text-plum-800">
                        {{ 'bell.view_all'|trans({}, 'notifications') }}
                    </a>
                </div>
            {% endif %}
        {% endif %}
    </div>
</div>
