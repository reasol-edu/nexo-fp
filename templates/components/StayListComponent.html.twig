<div {{ attributes.defaults(stimulus_controller('filter-persist', {
    centreId: centre.id.toRfc4122,
    active: this.hasActiveFilters,
})) }}>
    {% if centre.activeAcademicYear is null %}
        <div class="px-6 py-16 text-center">
            {{ ux_icon('heroicons:exclamation-circle', {class: 'mx-auto h-10 w-10 text-amber-300 mb-3'}) }}
            <p class="text-sm text-gray-500">{{ 'stays.no_active_year'|trans({}, 'stays') }}</p>
        </div>
    {% else %}
        {% set pagination = this.pagination %}

        {# ── Barra de filtros ──────────────────────────────────────────────────── #}
        <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden mb-4">
            <div class="px-4 py-3 flex flex-wrap gap-3 items-center bg-gray-50/50">

                {# Búsqueda #}
                <div class="relative flex-1 min-w-48">
                    <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                        {{ ux_icon('heroicons:magnifying-glass', {class: 'h-4 w-4 text-gray-400'}) }}
                    </div>
                    <input type="search"
                           data-model="norender|search"
                           data-action="input->live#action"
                           data-live-action-param="resetPage"
                           placeholder="{{ 'stays.search'|trans({}, 'stays') }}"
                           value="{{ search }}"
                           class="block w-full rounded-lg border border-gray-200 bg-white py-2 pl-9 pr-3 text-sm
                                  text-gray-900 placeholder-gray-400 focus:border-plum-500 focus:outline-none
                                  focus:ring-3 focus:ring-plum-500/20 transition-colors">
                </div>

                {# Familia profesional #}
                <select data-model="norender|familyId"
                        data-action="change->live#action"
                        data-live-action-param="changeFamilyFilter"
                        class="rounded-lg border border-gray-200 bg-white py-2 pl-3 pr-8 text-sm text-gray-700
                               focus:border-plum-500 focus:outline-none focus:ring-3 focus:ring-plum-500/20 transition-colors">
                    <option value="">{{ 'stays.filter.all_families'|trans({}, 'stays') }}</option>
                    {% for family in this.availableFamilies %}
                        <option value="{{ family.id }}" {{ familyId == family.id.toRfc4122 ? 'selected' : '' }}>
                            {{ family.name }}
                        </option>
                    {% endfor %}
                </select>

                {# Enseñanza #}
                <select data-model="norender|programmeId"
                        data-action="change->live#action"
                        data-live-action-param="resetPage"
                        class="rounded-lg border border-gray-200 bg-white py-2 pl-3 pr-8 text-sm text-gray-700
                               focus:border-plum-500 focus:outline-none focus:ring-3 focus:ring-plum-500/20 transition-colors">
                    <option value="">{{ 'stays.filter.all_programmes'|trans({}, 'stays') }}</option>
                    {% for p in this.availableProgrammes %}
                        <option value="{{ p.id }}" {{ programmeId == p.id.toRfc4122 ? 'selected' : '' }}>
                            {{ p.name }}
                        </option>
                    {% endfor %}
                </select>

                {# Limpiar filtros #}
                {% if this.hasActiveFilters %}
                    <button data-action="live#action"
                            data-live-action-param="clearFilters"
                            class="inline-flex items-center gap-1.5 rounded-lg border border-gray-300 bg-white
                                   px-3 py-2 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:border-gray-400
                                   transition-colors shrink-0">
                        {{ ux_icon('heroicons:x-mark', {class: 'h-3.5 w-3.5'}) }}
                        {{ 'stays.filter.clear'|trans({}, 'stays') }}
                    </button>
                {% endif %}

                <svg data-loading class="hidden h-4 w-4 text-plum-500 animate-spin shrink-0 ml-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
                </svg>
            </div>

            {# Filtros de período #}
            <div class="px-4 py-3 flex flex-wrap gap-2 border-t border-gray-100">
                <span class="self-center text-xs text-gray-400 mr-1">{{ 'stays.filter.show_label'|trans({}, 'stays') }}</span>

                <label class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium cursor-pointer
                              border transition-colors
                              {{ showCurrent
                                  ? 'border-green-300 bg-green-50 text-green-700'
                                  : 'border-gray-200 bg-white text-gray-400 hover:border-gray-300' }}">
                    <input type="checkbox" class="sr-only"
                           data-model="norender|showCurrent"
                           data-action="change->live#action"
                           data-live-action-param="resetPage"
                           {{ showCurrent ? 'checked' : '' }}>
                    <span class="h-1.5 w-1.5 rounded-full shrink-0 {{ showCurrent ? 'bg-green-700' : 'bg-gray-300' }}"></span>
                    {{ 'stays.period.current'|trans({}, 'stays') }}
                </label>

                <label class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium cursor-pointer
                              border transition-colors
                              {{ showFuture
                                  ? 'border-blue-300 bg-blue-50 text-blue-700'
                                  : 'border-gray-200 bg-white text-gray-400 hover:border-gray-300' }}">
                    <input type="checkbox" class="sr-only"
                           data-model="norender|showFuture"
                           data-action="change->live#action"
                           data-live-action-param="resetPage"
                           {{ showFuture ? 'checked' : '' }}>
                    <span class="h-1.5 w-1.5 rounded-full shrink-0 {{ showFuture ? 'bg-blue-700' : 'bg-gray-300' }}"></span>
                    {{ 'stays.period.future'|trans({}, 'stays') }}
                </label>

                <label class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium cursor-pointer
                              border transition-colors
                              {{ showPast
                                  ? 'border-gray-400 bg-gray-100 text-gray-600'
                                  : 'border-gray-200 bg-white text-gray-400 hover:border-gray-300' }}">
                    <input type="checkbox" class="sr-only"
                           data-model="norender|showPast"
                           data-action="change->live#action"
                           data-live-action-param="resetPage"
                           {{ showPast ? 'checked' : '' }}>
                    <span class="h-1.5 w-1.5 rounded-full shrink-0 {{ showPast ? 'bg-gray-600' : 'bg-gray-300' }}"></span>
                    {{ 'stays.period.past'|trans({}, 'stays') }}
                </label>
            </div>

        </div>

        {# ── Contenido ─────────────────────────────────────────────────────────── #}
        <div data-loading="addClass(opacity-50 pointer-events-none)" class="transition-opacity">
        {% set items = this.items %}
        {% set stats = this.stats %}

        {% if pagination.totalItems == 0 %}
            {% set has_filters = this.hasActiveFilters %}
            <div class="rounded-2xl border border-gray-200 bg-white shadow-xs px-6 py-16 text-center">
                {{ ux_icon('heroicons:briefcase', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
                <p class="text-sm text-gray-500">
                    {{ (has_filters ? 'stays.search_empty' : 'stays.empty')|trans({}, 'stays') }}
                </p>
                {% if has_filters %}
                    <button type="button"
                            data-action="live#action"
                            data-live-action-param="clearFilters"
                            class="mt-4 inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5
                                   text-xs font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                        {{ ux_icon('heroicons:x-mark', {class: 'h-3.5 w-3.5'}) }}
                        {{ 'stays.filter.clear'|trans({}, 'stays') }}
                    </button>
                {% endif %}
                {% if not has_filters and is_granted('stay.create', centre) %}
                    <a href="{{ path('app_stays_new') }}"
                       class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-plum-600 px-3 py-1.5
                              text-xs font-semibold text-white shadow-xs hover:bg-plum-700 transition-colors">
                        {{ ux_icon('heroicons:plus', {class: 'h-3.5 w-3.5'}) }}
                        {{ 'stays.new'|trans({}, 'stays') }}
                    </a>
                {% endif %}
            </div>
        {% else %}

            {# Grid de cards #}
            {% set today_str = "now"|date("Y-m-d") %}
            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
                {% for stay in items %}
                    {% set sid = stay.id.toRfc4122 %}
                    {% set s = stats[sid] ?? {students: 0, students_with_position: 0, total_positions: 0, occupied: 0, free: 0, companies: 0, signed: 0, state_draft: 0, state_pending: 0, state_done: 0} %}
                    {% set unassigned   = s.students - s.students_with_position %}
                    {% set unsigned     = s.students_with_position - (s.signed ?? 0) %}
                    {% set pct_students = s.students > 0 ? ((s.students_with_position / s.students) * 100)|round : 0 %}
                    {% set pct_occupied = s.total_positions > 0 ? ((s.occupied / s.total_positions) * 100)|round : 0 %}
                    {% set pct_free     = s.total_positions > 0 ? ((s.free / s.total_positions) * 100)|round : 0 %}

                    {% set end_str   = stay.endDate|date("Y-m-d") %}
                    {% set start_str = stay.startDate|date("Y-m-d") %}
                    {% set is_past    = end_str < today_str %}
                    {% set is_future  = start_str > today_str and not is_past %}
                    {% set is_current = not is_past and not is_future %}

                    <article class="rounded-2xl border bg-white shadow-xs overflow-hidden flex flex-col
                                    transition-all group
                                    {{ is_past
                                        ? 'border-gray-200 opacity-60 hover:opacity-100 hover:border-gray-300'
                                        : 'border-gray-200 hover:border-plum-200 hover:shadow-sm' }}">

                        {# ── Cabecera ──────────────────────────────────────────── #}
                        <div class="px-5 pt-6 pb-4 border-b border-gray-100">
                            <div class="flex items-start justify-between gap-2 mb-2">
                                <span class="inline-flex items-center rounded-full bg-plum-50 px-2.5 py-0.5 text-xs font-medium text-plum-700 shrink-0">
                                    {{ stay.programme.professionalFamily.name }}
                                </span>
                                {# Badge de estado #}
                                {% if is_current %}
                                    <span class="inline-flex items-center gap-1 rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700 shrink-0">
                                        <span class="h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse shrink-0"></span>
                                        {{ 'stays.period.badge.current'|trans({}, 'stays') }}
                                    </span>
                                {% elseif is_future %}
                                    <span class="inline-flex items-center gap-1 rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 shrink-0">
                                        {{ ux_icon('heroicons:clock', {class: 'h-3 w-3'}) }}
                                        {{ 'stays.period.badge.future'|trans({}, 'stays') }}
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500 shrink-0">
                                        {{ 'stays.period.badge.past'|trans({}, 'stays') }}
                                    </span>
                                {% endif %}
                            </div>
                            <div class="flex items-center justify-between gap-2">
                                <h3 class="font-semibold text-gray-900 text-sm leading-snug line-clamp-1 min-w-0" title="{{ stay.name }}">{{ stay.name }}</h3>
                                {% if unassigned > 0 or unsigned > 0 %}
                                    <div class="flex items-center gap-1 shrink-0">
                                        {% if unassigned > 0 %}
                                            <span class="inline-flex items-center gap-1 rounded-full bg-red-50 border border-red-200 px-2 py-0.5 text-xs font-medium text-red-700"
                                                  title="{{ 'stays.card.unassigned_hint'|trans({'%count%': unassigned}, 'stays') }}">
                                                {{ ux_icon('heroicons:exclamation-triangle', {class: 'h-3 w-3 shrink-0'}) }}
                                                {{ unassigned }}
                                            </span>
                                        {% endif %}
                                        {% if unsigned > 0 %}
                                            <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 border border-amber-200 px-2 py-0.5 text-xs font-medium text-amber-700"
                                                  title="{{ 'stays.card.unsigned_hint'|trans({'%count%': unsigned}, 'stays') }}">
                                                {{ ux_icon('heroicons:clock', {class: 'h-3 w-3 shrink-0'}) }}
                                                {{ unsigned }}
                                            </span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                            <p class="text-xs text-gray-500 mt-0.5 line-clamp-1">{{ stay.programme.name }}</p>

                            {# Fechas #}
                            <div class="mt-2 flex items-center gap-1 text-xs text-gray-400">
                                {{ ux_icon('heroicons:calendar-days', {class: 'h-3.5 w-3.5 shrink-0'}) }}
                                <span>{{ stay.startDate|date('d/m/Y') }}&nbsp;→&nbsp;{{ stay.endDate|date('d/m/Y') }}</span>
                            </div>
                        </div>

                        {# ── Stats: gráficas circulares ───────────────────────── #}
                        {%- set _c = 150.8 -%}
                        {%- set _r = 24 -%}
                        {# — segmentos de estudiantes — #}
                        {%- set _st = s.students -%}
                        {%- set _sw = s.students_with_position -%}
                        {%- set _sn = _st - _sw -%}
                        {%- set _dw = _st > 0 ? min((_sw / _st * _c)|round(2), _c - 0.01) : 0 -%}
                        {%- set _dn = _st > 0 ? min((_sn / _st * _c)|round(2), _c - 0.01) : 0 -%}
                        {# — segmentos de puestos — #}
                        {%- set _pt = s.total_positions -%}
                        {%- set _pf = s.free -%}
                        {%- set _pp = s.state_draft + s.state_pending -%}
                        {%- set _pr = s.state_done > s.signed ? s.state_done - s.signed : 0 -%}
                        {%- set _ps = s.signed -%}
                        {%- set _df = _pt > 0 ? min((_pf / _pt * _c)|round(2), _c - 0.01) : 0 -%}
                        {%- set _dp = _pt > 0 ? min((_pp / _pt * _c)|round(2), _c - 0.01) : 0 -%}
                        {%- set _dr = _pt > 0 ? min((_pr / _pt * _c)|round(2), _c - 0.01) : 0 -%}
                        {%- set _ds = _pt > 0 ? min((_ps / _pt * _c)|round(2), _c - 0.01) : 0 -%}
                        <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-3">

                            {# Donut — Estudiantes #}
                            <div class="flex flex-col items-center gap-1.5 shrink-0">
                                <svg viewBox="0 0 64 64" class="h-16 w-16" xmlns="http://www.w3.org/2000/svg">
                                    <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#f3f4f6" stroke-width="8"/>
                                    {%- if _st > 0 -%}
                                        {%- if _sw > 0 -%}
                                        {%- if _sn == 0 -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#34d399" stroke-width="8">
                                            <title>{{ _sw }} con puesto (100%)</title>
                                        </circle>
                                        {%- else -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#34d399" stroke-width="8"
                                                stroke-dasharray="{{ _dw }} {{ _c }}"
                                                stroke-dashoffset="{{ _c }}"
                                                transform="rotate(-90 32 32)">
                                            <title>{{ _sw }} con puesto ({{ (_sw / _st * 100)|round }}%)</title>
                                        </circle>
                                        {%- endif -%}
                                        {%- endif -%}
                                        {%- if _sn > 0 -%}
                                        {%- if _sw == 0 -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#fca5a5" stroke-width="8">
                                            <title>{{ _sn }} sin puesto (100%)</title>
                                        </circle>
                                        {%- else -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#fca5a5" stroke-width="8"
                                                stroke-dasharray="{{ _dn }} {{ _c }}"
                                                stroke-dashoffset="{{ (_c - _dw)|round(2) }}"
                                                transform="rotate(-90 32 32)">
                                            <title>{{ _sn }} sin puesto</title>
                                        </circle>
                                        {%- endif -%}
                                        {%- endif -%}
                                    {%- endif -%}
                                    <text x="32" y="32" text-anchor="middle" dominant-baseline="middle"
                                          font-size="{{ (_sw ~ '/' ~ _st)|length > 5 ? 8 : 10 }}"
                                          font-weight="bold" fill="#374151">{{ _sw }}/{{ _st }}</text>
                                </svg>
                                <span class="text-xs text-gray-400">{{ 'stays.card.students'|trans({}, 'stays') }}</span>
                            </div>

                            {# Stats centrales #}
                            <div class="flex-1 flex flex-col justify-center gap-2 min-w-0 text-xs">
                                <div class="flex items-center justify-between gap-1 min-w-0">
                                    <span class="text-gray-400 truncate min-w-0">{{ 'stays.card.students_with_position'|trans({}, 'stays') }}</span>
                                    <span class="font-semibold tabular-nums shrink-0
                                                 {{ pct_students >= 100 ? 'text-green-600' : (pct_students >= 50 ? 'text-amber-600' : 'text-gray-700') }}">
                                        {{ _sw }}/{{ _st }}&nbsp;<span class="font-normal text-gray-400">({{ pct_students }}%)</span>
                                    </span>
                                </div>
                                <div class="flex items-center justify-between gap-1 min-w-0">
                                    <span class="text-gray-400 truncate min-w-0">{{ 'stays.card.companies'|trans({}, 'stays') }}</span>
                                    <span class="font-semibold text-gray-700 tabular-nums shrink-0">{{ s.companies }}</span>
                                </div>
                                <div class="flex items-center justify-between gap-1 min-w-0">
                                    <span class="text-gray-400 truncate min-w-0">{{ 'stays.card.occupied'|trans({}, 'stays') }}</span>
                                    <span class="font-semibold text-gray-700 tabular-nums shrink-0">
                                        {{ s.occupied }}/{{ _pt }}&nbsp;<span class="font-normal text-gray-400">({{ pct_occupied }}%)</span>
                                    </span>
                                </div>
                                <div class="flex items-center justify-between gap-1 min-w-0">
                                    <span class="text-gray-400 truncate min-w-0">{{ 'stays.card.free'|trans({}, 'stays') }}</span>
                                    <span class="font-semibold text-gray-700 tabular-nums shrink-0">
                                        {{ s.free }}/{{ _pt }}&nbsp;<span class="font-normal text-gray-400">({{ pct_free }}%)</span>
                                    </span>
                                </div>
                            </div>

                            {# Donut — Puestos formativos #}
                            <div class="flex flex-col items-center gap-1.5 shrink-0">
                                <svg viewBox="0 0 64 64" class="h-16 w-16" xmlns="http://www.w3.org/2000/svg">
                                    <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#f3f4f6" stroke-width="8"/>
                                    {%- if _pt > 0 -%}
                                        {%- set _solo_f = _pp == 0 and _pr == 0 and _ps == 0 -%}
                                        {%- set _solo_p = _pf == 0 and _pr == 0 and _ps == 0 -%}
                                        {%- set _solo_r = _pf == 0 and _pp == 0 and _ps == 0 -%}
                                        {%- set _solo_s = _pf == 0 and _pp == 0 and _pr == 0 -%}
                                        {%- if _pf > 0 -%}
                                        {%- if _solo_f -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#d1d5db" stroke-width="8">
                                            <title>{{ _pf }} sin asignar (100%)</title>
                                        </circle>
                                        {%- else -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#d1d5db" stroke-width="8"
                                                stroke-dasharray="{{ _df }} {{ _c }}"
                                                stroke-dashoffset="{{ _c }}"
                                                transform="rotate(-90 32 32)">
                                            <title>{{ _pf }} sin asignar</title>
                                        </circle>
                                        {%- endif -%}
                                        {%- endif -%}
                                        {%- if _pp > 0 -%}
                                        {%- if _solo_p -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#fbbf24" stroke-width="8">
                                            <title>{{ _pp }} pendientes de Séneca (100%)</title>
                                        </circle>
                                        {%- else -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#fbbf24" stroke-width="8"
                                                stroke-dasharray="{{ _dp }} {{ _c }}"
                                                stroke-dashoffset="{{ (_c - _df)|round(2) }}"
                                                transform="rotate(-90 32 32)">
                                            <title>{{ _pp }} pendientes de Séneca</title>
                                        </circle>
                                        {%- endif -%}
                                        {%- endif -%}
                                        {%- if _pr > 0 -%}
                                        {%- if _solo_r -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#818cf8" stroke-width="8">
                                            <title>{{ _pr }} registrados sin firmar (100%)</title>
                                        </circle>
                                        {%- else -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#818cf8" stroke-width="8"
                                                stroke-dasharray="{{ _dr }} {{ _c }}"
                                                stroke-dashoffset="{{ (_c - _df - _dp)|round(2) }}"
                                                transform="rotate(-90 32 32)">
                                            <title>{{ _pr }} registrados sin firmar</title>
                                        </circle>
                                        {%- endif -%}
                                        {%- endif -%}
                                        {%- if _ps > 0 -%}
                                        {%- if _solo_s -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#34d399" stroke-width="8">
                                            <title>{{ _ps }} firmados (100%)</title>
                                        </circle>
                                        {%- else -%}
                                        <circle cx="32" cy="32" r="{{ _r }}" fill="none" stroke="#34d399" stroke-width="8"
                                                stroke-dasharray="{{ _ds }} {{ _c }}"
                                                stroke-dashoffset="{{ (_c - _df - _dp - _dr)|round(2) }}"
                                                transform="rotate(-90 32 32)">
                                            <title>{{ _ps }} firmados</title>
                                        </circle>
                                        {%- endif -%}
                                        {%- endif -%}
                                    {%- endif -%}
                                    <text x="32" y="32" text-anchor="middle" dominant-baseline="middle"
                                          font-size="{{ (_ps ~ '/' ~ _pt)|length > 5 ? 8 : 10 }}"
                                          font-weight="bold" fill="#374151">{{ _ps }}/{{ _pt }}</text>
                                </svg>
                                <span class="text-xs text-gray-400">{{ 'stays.card.positions'|trans({}, 'stays') }}</span>
                            </div>

                        </div>

                        {# ── Footer ────────────────────────────────────────────── #}
                        <div class="px-5 py-3 mt-auto flex items-center justify-end">
                            <a href="{{ path('app_stays_show', {id: sid}) }}"
                               class="inline-flex items-center gap-1.5 text-xs font-medium text-plum-600
                                      hover:text-plum-800 transition-colors group-hover:underline">
                                {{ 'stays.card.view'|trans({}, 'stays') }}
                                {{ ux_icon('heroicons:arrow-right', {class: 'h-3.5 w-3.5'}) }}
                            </a>
                        </div>

                    </article>
                {% endfor %}
            </div>

            {# ── Paginación ────────────────────────────────────────────────────── #}
            {% if pagination.totalPages > 1 %}
                <div class="mt-4 flex items-center justify-between gap-4 flex-wrap">
                    <p class="text-xs text-gray-500 shrink-0">
                        {{ 'pagination.summary'|trans({'%from%': pagination.firstItemIndex, '%to%': pagination.lastItemIndex, '%total%': pagination.totalItems}) }}
                    </p>
                    <nav class="flex items-center gap-1">
                        {% if pagination.hasPreviousPage %}
                            <button data-action="live#action" data-live-action-param="setPage" data-live-page-param="{{ pagination.previousPage }}"
                                    class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-200 text-gray-500 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                {{ ux_icon('heroicons:chevron-left', {class: 'h-4 w-4'}) }}
                            </button>
                        {% else %}
                            <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-100 text-gray-300 cursor-not-allowed">
                                {{ ux_icon('heroicons:chevron-left', {class: 'h-4 w-4'}) }}
                            </span>
                        {% endif %}
                        {% for p in pagination.pageRange %}
                            {% if p is null %}
                                <span class="inline-flex items-center justify-center h-8 px-1 text-xs text-gray-400 select-none">…</span>
                            {% elseif p == pagination.currentPage %}
                                <span class="inline-flex items-center justify-center h-8 min-w-8 px-2 rounded-lg bg-plum-600 text-white text-xs font-semibold">{{ p }}</span>
                            {% else %}
                                <button data-action="live#action" data-live-action-param="setPage" data-live-page-param="{{ p }}"
                                        class="inline-flex items-center justify-center h-8 min-w-8 px-2 rounded-lg border border-gray-200 text-gray-600 text-xs hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                    {{ p }}
                                </button>
                            {% endif %}
                        {% endfor %}
                        {% if pagination.hasNextPage %}
                            <button data-action="live#action" data-live-action-param="setPage" data-live-page-param="{{ pagination.nextPage }}"
                                    class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-200 text-gray-500 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
                            </button>
                        {% else %}
                            <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-100 text-gray-300 cursor-not-allowed">
                                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
                            </span>
                        {% endif %}
                    </nav>
                </div>
            {% endif %}

        {% endif %}
        </div>

    {% endif %}
</div>
