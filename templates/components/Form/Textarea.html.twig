{% props id, name, label, value = '', error = null, rows = 3, help = null, required = false %}
<div>
    <label for="{{ id }}" class="block text-sm font-medium text-gray-700 mb-1.5">{{ label }}</label>
    {% if help is not null %}
        <p class="text-xs text-gray-400 mb-2">{{ help }}</p>
    {% endif %}
    <textarea
        id="{{ id }}"
        name="{{ name }}"
        rows="{{ rows }}"
        {% if required %}required{% endif %}
        {{ attributes.without('class') }}
        class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900 transition-colors focus:outline-none focus:ring-3{{ error is not null ? ' border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20' : ' border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}"
    >{{ value }}</textarea>
    {% if error is not null %}
        <p class="mt-1.5 text-xs text-red-600">{{ error }}</p>
    {% endif %}
</div>
