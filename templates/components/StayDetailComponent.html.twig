{% macro state_badge(state) %}
    {% if state.value == 'PENDING' %}
        <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700">
            {{ 'stays.state.pending'|trans({}, 'stays') }}
        </span>
    {% elseif state.value == 'DONE' %}
        <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">
            {{ 'stays.state.done'|trans({}, 'stays') }}
        </span>
    {% else %}
        <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">
            {{ 'stays.state.draft'|trans({}, 'stays') }}
        </span>
    {% endif %}
{% endmacro %}

{%- set d                              = this.getData() -%}
{%- set stay                           = d.stay -%}
{%- set can_manage                     = d.can_manage -%}
{%- set can_add_position               = d.can_add_position -%}
{%- set manageable_position_ids        = d.manageable_position_ids -%}
{%- set stats                          = d.stats -%}
{%- set by_group                       = d.by_group -%}
{%- set ungrouped_students             = d.ungrouped_students -%}
{%- set student_position_map           = d.student_position_map -%}
{%- set unassigned_positions           = d.unassigned_positions -%}
{%- set compatible_positions_for_student = d.compatible_positions_for_student -%}
{%- set count_without_position         = d.count_without_position -%}
{%- set count_unsigned                 = d.count_unsigned -%}
{%- set programme_teachers             = d.programme_teachers -%}
{%- set workers_by_company_id          = d.workers_by_company_id -%}

{% set today_str = "now"|date("Y-m-d") %}
{% set end_str   = stay.endDate|date("Y-m-d") %}
{% set start_str = stay.startDate|date("Y-m-d") %}
{% set is_past    = end_str < today_str %}
{% set is_future  = start_str > today_str and not is_past %}
{% set is_current = not is_past and not is_future %}

{% set pct_students = stats.students > 0 ? ((stats.students_with_position / stats.students) * 100)|round : 0 %}
{% set pct_occupied = stats.total_positions > 0 ? ((stats.occupied / stats.total_positions) * 100)|round : 0 %}
{% set pct_free     = stats.total_positions > 0 ? ((stats.free / stats.total_positions) * 100)|round : 0 %}

<div {{ attributes }} class="px-6 py-8 max-w-6xl mx-auto space-y-5">

    {# ── Toasts de acciones en vivo ───────────────────────────────────────── #}
    <div class="fixed bottom-4 right-4 z-50 space-y-2 pointer-events-none">
        {% for message in app.flashes('live_toast') %}
            <div class="js-live-toast pointer-events-auto flex items-center gap-2 rounded-xl bg-gray-900 px-4 py-3 text-sm text-white shadow-lg">
                {{ ux_icon('heroicons:check-circle', {class: 'h-4 w-4 text-green-400 shrink-0'}) }}
                {{ message }}
            </div>
        {% endfor %}
    </div>

    {# ── Cabecera ─────────────────────────────────────────────────────────── #}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <div class="px-6 py-5">

            <div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
                <a href="{{ path('app_stays_index') }}" class="hover:text-plum-600 transition-colors">
                    {{ 'stays.title'|trans({}, 'stays') }}
                </a>
                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
                <span class="truncate text-gray-700">{{ stay.name }}</span>
            </div>

            <div class="flex flex-wrap items-start gap-3">
                <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                        <span class="inline-flex items-center rounded-full bg-plum-50 px-2.5 py-0.5 text-xs font-medium text-plum-700">
                            {{ stay.programme.professionalFamily.name }}
                        </span>
                        {% if is_current %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">
                                <span class="h-1.5 w-1.5 rounded-full animate-pulse shrink-0" style="background-color: #22c55e"></span>
                                {{ 'stays.period.badge.current'|trans({}, 'stays') }}
                            </span>
                        {% elseif is_future %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700">
                                {{ ux_icon('heroicons:clock', {class: 'h-3 w-3'}) }}
                                {{ 'stays.period.badge.future'|trans({}, 'stays') }}
                            </span>
                        {% else %}
                            <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">
                                {{ 'stays.period.badge.past'|trans({}, 'stays') }}
                            </span>
                        {% endif %}
                    </div>
                    <h1 class="text-2xl font-bold text-gray-900 leading-tight">{{ stay.name }}</h1>
                    <p class="mt-0.5 text-sm text-gray-500">{{ stay.programme.name }}</p>
                </div>

                <div class="flex items-center gap-2 shrink-0">
                    <div class="flex items-center gap-1.5 text-sm text-gray-500 rounded-xl border border-gray-200 px-3 py-2">
                        {{ ux_icon('heroicons:calendar-days', {class: 'h-4 w-4 shrink-0 text-gray-400'}) }}
                        <span>{{ stay.startDate|date('d/m/Y') }}</span>
                        <span class="text-gray-300">→</span>
                        <span>{{ stay.endDate|date('d/m/Y') }}</span>
                    </div>
                    <a href="{{ path('app_stays_report', {id: stay.id.toRfc4122}) }}"
                       target="_blank"
                       class="inline-flex items-center gap-1 rounded-xl border border-gray-200 px-3 py-2
                              text-sm text-gray-500 hover:border-gray-300 hover:text-gray-700 hover:bg-gray-50 transition-colors"
                       title="{{ 'stays.report.btn'|trans({}, 'stays') }}">
                        {{ ux_icon('heroicons:document-arrow-down', {class: 'h-4 w-4'}) }}
                    </a>
                    <a href="{{ path('app_stays_export', {id: stay.id.toRfc4122}) }}"
                       class="inline-flex items-center gap-1 rounded-xl border border-gray-200 px-3 py-2
                              text-sm text-gray-500 hover:border-gray-300 hover:text-gray-700 hover:bg-gray-50 transition-colors"
                       title="{{ 'stays.export.btn'|trans({}, 'stays') }}">
                        {{ ux_icon('heroicons:table-cells', {class: 'h-4 w-4'}) }}
                    </a>
                    {% if can_manage %}
                        <a href="{{ path('app_stays_edit', {id: stay.id.toRfc4122}) }}"
                           class="inline-flex items-center gap-1 rounded-xl border border-gray-200 px-3 py-2
                                  text-sm text-gray-500 hover:border-gray-300 hover:text-gray-700 hover:bg-gray-50 transition-colors"
                           title="{{ 'stays.edit.title'|trans({}, 'stays') }}">
                            {{ ux_icon('heroicons:pencil-square', {class: 'h-4 w-4'}) }}
                        </a>
                        <form method="post"
                              action="{{ path('app_stays_delete', {id: stay.id.toRfc4122}) }}"
                              class="js-confirm-form"
                              data-confirm="{{ 'stays.delete.confirm'|trans({}, 'stays')|e('html_attr') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_stay_' ~ stay.id.toRfc4122) }}">
                            <button type="button"
                                    class="js-confirm-trigger inline-flex items-center gap-1 rounded-xl border border-red-200 px-3 py-2
                                           text-sm text-red-500 hover:border-red-300 hover:text-red-700 hover:bg-red-50 transition-colors"
                                    title="{{ 'stays.delete.btn'|trans({}, 'stays') }}">
                                {{ ux_icon('heroicons:trash', {class: 'h-4 w-4'}) }}
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ── Stats ─────────────────────────────────────────────────────────── #}
        <div class="border-t border-gray-100 bg-gray-50/50 grid grid-cols-2 sm:grid-cols-4 divide-x divide-gray-100">
            <div class="px-5 py-4">
                <p class="text-xs text-gray-500 mb-1">{{ 'stays.card.students_with_position'|trans({}, 'stays') }}</p>
                <p class="text-lg font-bold tabular-nums
                          {{ pct_students >= 100 ? 'text-green-600' : (pct_students >= 50 ? 'text-amber-600' : 'text-gray-900') }}">
                    {{ stats.students_with_position }}<span class="text-sm font-normal text-gray-400">/{{ stats.students }}</span>
                </p>
                <p class="text-xs text-gray-400 mt-0.5">{{ pct_students }}%</p>
            </div>
            <div class="px-5 py-4">
                <p class="text-xs text-gray-500 mb-1">{{ 'stays.card.companies'|trans({}, 'stays') }}</p>
                <p class="text-lg font-bold text-gray-900 tabular-nums">{{ stats.companies }}</p>
                <p class="text-xs text-gray-400 mt-0.5">&nbsp;</p>
            </div>
            <div class="px-5 py-4">
                <p class="text-xs text-gray-500 mb-1">{{ 'stays.card.occupied'|trans({}, 'stays') }}</p>
                <p class="text-lg font-bold text-gray-900 tabular-nums">
                    {{ stats.occupied }}<span class="text-sm font-normal text-gray-400">/{{ stats.total_positions }}</span>
                </p>
                <p class="text-xs text-gray-400 mt-0.5">{{ pct_occupied }}%</p>
            </div>
            <div class="px-5 py-4">
                <p class="text-xs text-gray-500 mb-1">{{ 'stays.card.free'|trans({}, 'stays') }}</p>
                <p class="text-lg font-bold text-gray-900 tabular-nums">
                    {{ stats.free }}<span class="text-sm font-normal text-gray-400">/{{ stats.total_positions }}</span>
                </p>
                <p class="text-xs text-gray-400 mt-0.5">{{ pct_free }}%</p>
            </div>
        </div>
    </div>

    {# ── Estudiantes ──────────────────────────────────────────────────────── #}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">

        <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-2 flex-wrap">
            <h2 class="text-sm font-semibold text-gray-900 shrink-0">
                {{ 'stays.show.students_title'|trans({}, 'stays') }}
            </h2>
            <span class="text-xs text-gray-400 tabular-nums shrink-0">{{ stats.students }}</span>

            {% if count_without_position > 0 %}
                <span class="inline-flex items-center gap-1 rounded-full bg-red-50 border border-red-200 px-2 py-0.5 text-xs font-medium text-red-700 shrink-0">
                    {{ ux_icon('heroicons:exclamation-triangle', {class: 'h-3 w-3 shrink-0'}) }}
                    {{ 'stays.show.students_no_position'|trans({'%count%': count_without_position}, 'stays') }}
                </span>
            {% endif %}

            {% if count_unsigned > 0 %}
                <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 border border-amber-200 px-2 py-0.5 text-xs font-medium text-amber-700 shrink-0">
                    {{ ux_icon('heroicons:clock', {class: 'h-3 w-3 shrink-0'}) }}
                    {{ 'stays.show.students_unsigned'|trans({'%count%': count_unsigned}, 'stays') }}
                </span>
            {% endif %}

            <span class="ml-auto"></span>
            {% if manageable_position_ids is not empty and (by_group is not empty or ungrouped_students is not empty) %}
                <button type="button"
                        aria-pressed="false"
                        class="js-quick-toggle inline-flex items-center gap-1.5 rounded-lg border border-gray-300 bg-white
                               px-3 py-1.5 text-xs font-semibold text-gray-700 shadow-xs
                               hover:border-gray-400 hover:bg-gray-50 transition-colors shrink-0"
                        title="{{ 'stays.quick_mode.hint'|trans({}, 'stays') }}">
                    {{ ux_icon('heroicons:bolt', {class: 'h-3.5 w-3.5'}) }}
                    {{ 'stays.quick_mode.toggle'|trans({}, 'stays') }}
                </button>
            {% endif %}
            {% if can_manage %}
                <a href="{{ path('app_stays_manage_students', {id: stay.id.toRfc4122}) }}"
                   class="inline-flex items-center gap-1.5 rounded-lg border border-gray-300 bg-white
                          px-3 py-1.5 text-xs font-semibold text-gray-700 shadow-xs
                          hover:border-gray-400 hover:bg-gray-50 transition-colors shrink-0">
                    {{ ux_icon('heroicons:user-group', {class: 'h-3.5 w-3.5'}) }}
                    {{ 'stays.students.manage_btn'|trans({}, 'stays') }}
                </a>
            {% endif %}
        </div>

        {% if by_group is empty and ungrouped_students is empty %}
            <div class="px-6 py-14 text-center">
                {{ ux_icon('heroicons:user-group', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
                <p class="text-sm text-gray-500">{{ 'stays.show.students_empty'|trans({}, 'stays') }}</p>
                {% if can_manage %}
                    <a href="{{ path('app_stays_manage_students', {id: stay.id.toRfc4122}) }}"
                       class="mt-4 inline-flex items-center gap-1.5 rounded-lg border border-plum-600 bg-plum-600
                              px-3 py-1.5 text-xs font-semibold text-white shadow-xs
                              hover:border-plum-700 hover:bg-plum-700 transition-colors">
                        {{ ux_icon('heroicons:user-group', {class: 'h-3.5 w-3.5'}) }}
                        {{ 'stays.students.manage_btn'|trans({}, 'stays') }}
                    </a>
                {% endif %}
            </div>
        {% else %}
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-100 bg-gray-50/50">
                            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide w-44">
                                {{ 'stays.show.col.student'|trans({}, 'stays') }}
                            </th>
                            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide w-64">
                                {{ 'stays.show.col.workcenter'|trans({}, 'stays') }}
                            </th>
                            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell w-48">
                                {{ 'stays.show.col.tutor'|trans({}, 'stays') }}
                            </th>
                            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell w-48">
                                {{ 'stays.show.col.workplace_mentor'|trans({}, 'stays') }}
                            </th>
                            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden sm:table-cell w-36">
                                {{ 'stays.show.col.state'|trans({}, 'stays') }}
                            </th>
                            {% if can_manage or manageable_position_ids is not empty %}<th class="px-3 py-3 w-24"></th>{% endif %}
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">

                        {% for entry in by_group %}
                            <tr>
                                <td colspan="99" class="px-5 py-2 bg-gray-50/70 border-y border-gray-100">
                                    <div class="flex items-center gap-2">
                                        {{ ux_icon('heroicons:users', {class: 'h-3.5 w-3.5 text-gray-400 shrink-0'}) }}
                                        <span class="text-xs font-semibold text-gray-600 uppercase tracking-wide">{{ entry.group.name }}</span>
                                    </div>
                                </td>
                            </tr>

                            {% for student in entry.students %}
                                {% set sid = student.id.toRfc4122 %}
                                {% set position = student_position_map[sid] is defined ? student_position_map[sid] : null %}
                                {% if position is null %}
                                    {% set row_bg = 'hover:bg-gray-50/50' %}
                                {% elseif position.signed %}
                                    {% set row_bg = 'bg-green-50/60 hover:bg-green-50' %}
                                {% else %}
                                    {% set row_bg = 'bg-amber-50/60 hover:bg-amber-50' %}
                                {% endif %}
                                <tr class="{{ row_bg }} transition-colors js-student-row">

                                    <td class="px-5 py-3 w-44">
                                        <p class="font-medium text-gray-900 leading-snug">{{ student.name.full() }}</p>
                                        <p class="text-xs text-gray-400 font-mono mt-0.5">{{ student.studentId }}</p>
                                    </td>

                                    <td class="px-5 py-3 w-64">
                                        {% if position is null %}
                                            {% set compatible = compatible_positions_for_student[sid] ?? [] %}
                                            {% set manageable_compatible = compatible|filter(pos => manageable_position_ids[pos.id.toRfc4122] is defined) %}
                                            {% if manageable_compatible is not empty %}
                                                <form class="js-assign-form" data-student-id="{{ sid }}">
                                                    <button type="button"
                                                            class="js-assign-trigger inline-flex items-center gap-1 text-xs font-medium text-red-500 hover:text-red-700 transition-colors"
                                                            title="{{ 'stays.show.assign_position_hint'|trans({}, 'stays') }}">
                                                        {{ ux_icon('heroicons:x-circle', {class: 'h-3.5 w-3.5 shrink-0'}) }}
                                                        {{ 'stays.show.position_none'|trans({}, 'stays') }}
                                                        {{ ux_icon('heroicons:chevron-down', {class: 'h-3 w-3 shrink-0 opacity-60'}) }}
                                                    </button>
                                                    <div class="js-assign-select hidden mt-1.5">
                                                        <select class="js-assign-dropdown w-full text-xs rounded-lg border border-plum-300 bg-white px-2 py-1.5 text-gray-700 shadow-xs focus:outline-none focus:ring-1 focus:ring-plum-500 focus:border-plum-500">
                                                            <option value="">{{ 'stays.show.assign_position_placeholder'|trans({}, 'stays') }}</option>
                                                            {% for pos in manageable_compatible %}
                                                                <option value="{{ pos.id.toRfc4122 }}"
                                                                        data-company="{{ pos.workcenter ? pos.workcenter.company.name|e('html_attr') : '' }}"
                                                                        data-center="{{ pos.workcenter ? pos.workcenter.name|e('html_attr') : '' }}"
                                                                        data-city="{{ pos.workcenter and pos.workcenter.city ? pos.workcenter.city|e('html_attr') : '' }}"
                                                                        data-details="{{ pos.details ? pos.details|e('html_attr') : '' }}">
                                                                    {{- pos.workcenter ? pos.workcenter.company.name ~ ' — ' ~ pos.workcenter.name : '—' -}}
                                                                </option>
                                                            {% endfor %}
                                                        </select>
                                                    </div>
                                                </form>
                                            {% else %}
                                                <span class="inline-flex items-center gap-1 text-xs font-medium text-red-500">
                                                    {{ ux_icon('heroicons:x-circle', {class: 'h-3.5 w-3.5 shrink-0'}) }}
                                                    {{ 'stays.show.position_none'|trans({}, 'stays') }}
                                                </span>
                                            {% endif %}
                                        {% elseif position.workcenter %}
                                            <p class="font-medium text-gray-900 leading-snug">{{ position.workcenter.company.name }}</p>
                                            <p class="text-xs text-gray-500 mt-0.5">{{ position.workcenter.name }}{% if position.workcenter.city %} · {{ position.workcenter.city }}{% endif %}</p>
                                        {% else %}
                                            <span class="text-gray-300">{{ 'stays.show.no_workcenter'|trans({}, 'stays') }}</span>
                                        {% endif %}
                                    </td>

                                    <td class="px-5 py-3 hidden lg:table-cell w-48">
                                        {% if position and position.academicTutor %}
                                            <p class="text-gray-700 leading-snug">{{ position.academicTutor.name.full() }}</p>
                                        {% elseif position is not null and manageable_position_ids[position.id.toRfc4122] is defined %}
                                            <form class="js-inline-assign-form"
                                                  data-position-id="{{ position.id.toRfc4122 }}"
                                                  data-live-action="setAcademicTutor"
                                                  data-live-arg-name="teacherId">
                                                <button type="button"
                                                        class="js-inline-trigger inline-flex items-center gap-1 text-xs font-medium text-gray-400 hover:text-gray-600 transition-colors">
                                                    {{ 'stays.show.tutor_none'|trans({}, 'stays') }}
                                                    {{ ux_icon('heroicons:chevron-down', {class: 'h-3 w-3 shrink-0 opacity-60'}) }}
                                                </button>
                                                <div class="js-inline-select-wrap hidden mt-1.5">
                                                    <select class="js-inline-select w-full">
                                                        <option value="">{{ 'stays.show.assign_tutor_placeholder'|trans({}, 'stays') }}</option>
                                                        {% for teacher in programme_teachers %}
                                                            <option value="{{ teacher.id.toRfc4122 }}">{{ teacher.name.lastName }} {{ teacher.name.firstName }}</option>
                                                        {% endfor %}
                                                    </select>
                                                </div>
                                            </form>
                                        {% else %}
                                            <span class="text-gray-300">{{ 'stays.show.no_tutor'|trans({}, 'stays') }}</span>
                                        {% endif %}
                                    </td>

                                    <td class="px-5 py-3 hidden lg:table-cell w-48">
                                        {% if position and position.workplaceMentor %}
                                            <p class="text-gray-700 leading-snug">{{ position.workplaceMentor.name.full() }}</p>
                                        {% elseif position is not null and position.workcenter and manageable_position_ids[position.id.toRfc4122] is defined %}
                                            {% set cid = position.workcenter.company.id.toRfc4122 %}
                                            {% set mentorOpts = workers_by_company_id[cid] ?? [] %}
                                            {% if mentorOpts is not empty %}
                                                <form class="js-inline-assign-form"
                                                      data-position-id="{{ position.id.toRfc4122 }}"
                                                      data-live-action="setWorkplaceMentor"
                                                      data-live-arg-name="workerId">
                                                    <button type="button"
                                                            class="js-inline-trigger inline-flex items-center gap-1 text-xs font-medium text-gray-400 hover:text-gray-600 transition-colors">
                                                        {{ 'stays.show.mentor_none'|trans({}, 'stays') }}
                                                        {{ ux_icon('heroicons:chevron-down', {class: 'h-3 w-3 shrink-0 opacity-60'}) }}
                                                    </button>
                                                    <div class="js-inline-select-wrap hidden mt-1.5">
                                                        <select class="js-inline-select w-full">
                                                            <option value="">{{ 'stays.show.assign_mentor_placeholder'|trans({}, 'stays') }}</option>
                                                            {% for w in mentorOpts %}
                                                                <option value="{{ w.id.toRfc4122 }}">{{ w.name.lastName }} {{ w.name.firstName }}</option>
                                                            {% endfor %}
                                                        </select>
                                                    </div>
                                                </form>
                                            {% else %}
                                                <span class="text-gray-300">{{ 'stays.show.no_tutor'|trans({}, 'stays') }}</span>
                                            {% endif %}
                                        {% else %}
                                            <span class="text-gray-300">{{ 'stays.show.no_tutor'|trans({}, 'stays') }}</span>
                                        {% endif %}
                                    </td>

                                    <td class="px-5 py-3 hidden sm:table-cell w-36">
                                        {% if position %}
                                            <div class="space-y-1">
                                                {{ _self.state_badge(position.state) }}
                                                {% if position.signed %}
                                                    <span class="inline-flex items-center gap-1 text-xs font-medium text-green-600">
                                                        {{ ux_icon('heroicons:check-circle', {class: 'h-3.5 w-3.5 shrink-0'}) }}
                                                        {{ 'stays.show.signed'|trans({}, 'stays') }}
                                                    </span>
                                                {% else %}
                                                    <span class="text-xs text-gray-400">{{ 'stays.show.not_signed'|trans({}, 'stays') }}</span>
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </td>

                                    {% if position is not null and manageable_position_ids[position.id.toRfc4122] is defined %}
                                    <td class="px-3 py-3 text-right w-24">
                                        <div class="inline-flex items-center gap-1">
                                            {% if position.state.value == 'DRAFT' %}
                                                <button type="button"
                                                        data-action="live#action"
                                                        data-live-action-param="unassignPosition"
                                                        data-live-position-id-param="{{ position.id.toRfc4122 }}"
                                                        class="inline-flex items-center rounded-lg border border-amber-200 p-1.5
                                                               text-amber-500 hover:border-amber-300 hover:text-amber-700 hover:bg-amber-50 transition-colors"
