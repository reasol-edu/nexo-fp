<script type="module" data-live-ignore>
import TomSelect from 'tom-select';
import { getComponent } from '@symfony/ux-live-component';

let liveEl  = null;
let liveComp = null;
let quickMode = false;

const LABEL_CANCEL  = '{{ 'ui.cancel'|trans }}';
const LABEL_CONFIRM = '{{ 'ui.confirm_delete'|trans }}';

// ── Single delegated listener for all interactive clicks ──────────────────────
// Handles confirm panels, assign triggers, and inline triggers. Using delegation
// (instead of per-element listeners) avoids stale listener accumulation across
// Idiomorph re-renders, which morph elements in place but fire live:render after.
function setupEventDelegation() {
    liveEl.addEventListener('click', function (e) {

        // Quick assignment mode toggle
        const quickToggle = e.target.closest('.js-quick-toggle');
        if (quickToggle) {
            quickMode = !quickMode;
            applyQuickMode();
            return;
        }

        // Confirm panel
        const confirmTrigger = e.target.closest('.js-confirm-trigger');
        if (confirmTrigger) {
            e.stopPropagation();
            const form = confirmTrigger.closest('.js-confirm-form');
            if (!form || form.querySelector('.js-confirm-panel')) return;
            const panel = document.createElement('div');
            panel.className = 'js-confirm-panel absolute z-20 right-0 mt-1 w-64 rounded-xl border border-red-200 bg-white shadow-lg p-3 text-sm';
            panel.innerHTML =
                '<p class="text-gray-700 mb-2.5 leading-snug">' + (form.dataset.confirm ?? '') + '</p>' +
                '<div class="flex items-center justify-end gap-2">' +
                '  <button type="button" class="js-confirm-cancel rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-medium text-gray-600 hover:bg-gray-50 transition-colors">' + LABEL_CANCEL + '</button>' +
                '  <button type="submit" class="rounded-lg bg-red-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-red-700 transition-colors">' + LABEL_CONFIRM + '</button>' +
                '</div>';
            form.style.position = 'relative';
            form.appendChild(panel);
            panel.querySelector('.js-confirm-cancel').addEventListener('click', function () { panel.remove(); });
            function onOutside(ev) {
                if (!panel.isConnected) { document.removeEventListener('click', onOutside); return; }
                if (!panel.contains(ev.target)) { panel.remove(); document.removeEventListener('click', onOutside); }
            }
            setTimeout(function () { document.addEventListener('click', onOutside); }, 0);
            return;
        }

        // Position assign dropdown trigger
        const assignTrigger = e.target.closest('.js-assign-trigger');
        if (assignTrigger) {
            const form     = assignTrigger.closest('.js-assign-form');
            if (!form) return;
            const wrap     = form.querySelector('.js-assign-select');
            const dropdown = form.querySelector('.js-assign-dropdown');
            if (!wrap || !dropdown || !dropdown.tomselect) return;
            wrap.classList.remove('hidden');
            assignTrigger.classList.add('hidden');
            requestAnimationFrame(function () { dropdown.tomselect.open(); });
            return;
        }

        // Inline tutor / mentor dropdown trigger
        const inlineTrigger = e.target.closest('.js-inline-trigger');
        if (inlineTrigger) {
            const form     = inlineTrigger.closest('.js-inline-assign-form');
            if (!form) return;
            const wrap     = form.querySelector('.js-inline-select-wrap');
            const dropdown = form.querySelector('.js-inline-select');
            if (!wrap || !dropdown || !dropdown.tomselect) return;
            wrap.classList.remove('hidden');
            inlineTrigger.classList.add('hidden');
            requestAnimationFrame(function () { dropdown.tomselect.open(); });
            return;
        }
    });
}

// ── Tom Select helpers ────────────────────────────────────────────────────────
// No data-live-ignore on forms: Idiomorph removes the Tom Select wrapper on each
// re-render and restores a plain <select> from the new server HTML, so
// dropdown.tomselect is always undefined on a fresh render cycle. Trigger clicks
// are handled via delegation above, so no per-form click listeners are added.
function initAssignForm(form) {
    const trigger  = form.querySelector('.js-assign-trigger');
    const wrap     = form.querySelector('.js-assign-select');
    const dropdown = form.querySelector('.js-assign-dropdown');
    if (!trigger || !wrap || !dropdown || dropdown.tomselect) return;

    const studentId = form.dataset.studentId;
    const ph = dropdown.querySelector('option[value=""]')?.textContent.trim() ?? '';
    const opts = [{ value: '', text: ph, company: '', center: '', city: '', details: '', search: '' }];
    dropdown.querySelectorAll('option:not([value=""])').forEach(function (opt) {
        const company = opt.dataset.company ?? '', center = opt.dataset.center ?? '';
        const city    = opt.dataset.city    ?? '', details = opt.dataset.details ?? '';
        opts.push({ value: opt.value, text: opt.textContent.trim(), company, center, city, details,
            search: [company, center, city, details].filter(Boolean).join(' ') });
    });

    new TomSelect(dropdown, {
        options: opts, items: [], valueField: 'value', labelField: 'text',
        searchField: ['search'], allowEmptyOption: false, create: false, maxOptions: null,
        placeholder: ph, wrapperClass: 'ts-wrapper ts-local', dropdownParent: 'body',
        render: {
            option: function (d, esc) {
                if (!d.value) return '<div class="py-0.5 text-gray-400 italic">' + esc(d.text) + '</div>';
                const citySpan = d.city    ? ' <span class="ts-wc-city">· ' + esc(d.city) + '</span>' : '';
                const detailEl = d.details ? '<p class="ts-pos-details">' + esc(d.details) + '</p>' : '';
                return '<div class="ts-pos-option"><p class="ts-pos-company">' + esc(d.company) + '</p>'
                     + '<p class="ts-pos-sub">' + esc(d.center) + citySpan + '</p>' + detailEl + '</div>';
            },
            item: function (d, esc) {
                if (!d.value) return '<div>' + esc(d.text) + '</div>';
                return '<div class="ts-wc-item"><span class="ts-wc-company">' + esc(d.company) + '</span>'
                     + '<span class="ts-wc-sep">·</span><span class="ts-wc-sub">' + esc(d.center) + '</span></div>';
            },
            no_results: function () {
                return '<div class="no-results px-3 py-2 text-sm">{{ 'stays.position.field.workcenter_no_results'|trans({}, 'stays') }}</div>';
            },
        },
        onChange: function (positionId) {
            if (!positionId || !liveComp) return;
            liveComp.action('assignPosition', { studentId, positionId });
        },
        onDropdownClose: function () {
            if (quickMode) return;
            wrap.classList.add('hidden');
            trigger.classList.remove('hidden');
        },
    });
}

function initInlineForm(form) {
    const trigger    = form.querySelector('.js-inline-trigger');
    const wrap       = form.querySelector('.js-inline-select-wrap');
    const dropdown   = form.querySelector('.js-inline-select');
    if (!trigger || !wrap || !dropdown || dropdown.tomselect) return;

    const positionId = form.dataset.positionId;
    const actionName = form.dataset.liveAction;
    const argName    = form.dataset.liveArgName;

    const ph   = dropdown.querySelector('option[value=""]')?.textContent.trim() ?? '';
    const opts = [{ value: '', text: ph }];
    dropdown.querySelectorAll('option:not([value=""])').forEach(function (opt) {
        opts.push({ value: opt.value, text: opt.textContent.trim() });
    });

    new TomSelect(dropdown, {
        options: opts, items: [], valueField: 'value', labelField: 'text',
        searchField: ['text'], allowEmptyOption: false, create: false, maxOptions: null,
        placeholder: ph, wrapperClass: 'ts-wrapper ts-local', dropdownParent: 'body',
        onChange: function (value) {
            if (!value || !liveComp) return;
            const params = { positionId };
            params[argName] = value;
            liveComp.action(actionName, params);
        },
        onDropdownClose: function () {
            if (quickMode) return;
            wrap.classList.add('hidden');
            trigger.classList.remove('hidden');
        },
    });
}

function initAllForms() {
    liveEl.querySelectorAll('.js-assign-form').forEach(initAssignForm);
    liveEl.querySelectorAll('.js-inline-assign-form').forEach(initInlineForm);
}

// ── Quick assignment mode ─────────────────────────────────────────────────────
// Pure client-side: reveals the (already rendered) assignment selectors in every
// row. Re-applied after each render because Idiomorph restores the server HTML.
function applyQuickMode() {
    liveEl.querySelectorAll('.js-assign-form, .js-inline-assign-form').forEach(function (form) {
        const trigger = form.querySelector('.js-assign-trigger, .js-inline-trigger');
        const wrap    = form.querySelector('.js-assign-select, .js-inline-select-wrap');
        if (!trigger || !wrap) return;
        wrap.classList.toggle('hidden', !quickMode);
        trigger.classList.toggle('hidden', quickMode);
    });
    const btn = liveEl.querySelector('.js-quick-toggle');
    if (btn) {
        btn.setAttribute('aria-pressed', quickMode ? 'true' : 'false');
        btn.classList.toggle('bg-plum-600', quickMode);
        btn.classList.toggle('border-plum-600', quickMode);
        btn.classList.toggle('text-white', quickMode);
        btn.classList.toggle('bg-white', !quickMode);
        btn.classList.toggle('border-gray-300', !quickMode);
        btn.classList.toggle('text-gray-700', !quickMode);
    }
}

// ── Toast auto-dismiss ────────────────────────────────────────────────────────
function dismissToasts() {
    liveEl.querySelectorAll('.js-live-toast').forEach(function (toast) {
        if (toast.dataset.toastTimer) return;
        toast.dataset.toastTimer = '1';
        setTimeout(function () {
            toast.classList.add('opacity-0', 'transition-opacity', 'duration-300');
            setTimeout(function () { toast.remove(); }, 300);
        }, 3000);
    });
}

function onRender() {
    initAllForms();
    applyQuickMode();
    dismissToasts();
}

liveEl = document.querySelector('[data-controller~="live"]');
if (liveEl) {
    getComponent(liveEl).then(function (component) {
        liveComp = component;
        setupEventDelegation();
        onRender();
        component.on('render:finished', onRender);
    });
}
</script>

</div>
