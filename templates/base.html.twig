<!DOCTYPE html>
<html lang="es" class="h-full">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}{{ 'app.welcome'|trans }} · {{ app_name }}{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..700&display=swap" rel="stylesheet">
        <link rel="icon" type="image/png" href="{{ asset('static/favicon-96x96.png') }}" sizes="96x96" />
        <link rel="icon" type="image/svg+xml" href="{{ asset('static/favicon.svg') }}" />
        <link rel="shortcut icon" href="{{ asset('static/favicon.ico') }}" />
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('static/apple-touch-icon.png') }}" />
        <link rel="manifest" href="{{ asset('static/site.webmanifest') }}" />
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="h-full font-sans antialiased">
        {% block body %}{% endblock %}
    </body>
</html>
