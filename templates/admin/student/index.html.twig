{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'students.title'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto space-y-6">

    <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
                <a href="{{ path('app_educational_centre_index') }}" class="hover:text-plum-600 transition-colors">{{ 'educational_centre'|trans({}, 'navigation') }}</a>
                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            </div>
            <h1 class="text-2xl font-bold text-gray-900">{{ 'students.title'|trans({}, 'admin') }}</h1>
            {% if centre.activeAcademicYear %}
                <p class="mt-1 text-sm text-gray-500">{{ centre.activeAcademicYear.name }}</p>
            {% endif %}
        </div>
        {% if centre.activeAcademicYear %}
            <div class="flex items-center gap-2 shrink-0">
                <a href="{{ path('app_admin_students_import', {centreId: centre.id}) }}"
                   class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700
                          hover:bg-gray-50 hover:border-gray-300 transition-colors shadow-xs">
                    {{ ux_icon('heroicons:arrow-up-tray', {class: 'h-4 w-4'}) }}
                    {{ 'students.import.button'|trans({}, 'admin') }}
                </a>
                <a href="{{ path('app_admin_students_new', {centreId: centre.id}) }}"
                   class="inline-flex items-center gap-2 rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                          hover:bg-plum-700 transition-colors shadow-xs">
                    {{ ux_icon('heroicons:plus', {class: 'h-4 w-4'}) }}
                    {{ 'students.new'|trans({}, 'admin') }}
                </a>
            </div>
        {% endif %}
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:Admin:StudentListComponent :centre="centre" />
    </div>

</div>
{% endblock %}
