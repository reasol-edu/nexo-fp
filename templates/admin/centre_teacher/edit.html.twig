{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'centre_teachers.edit.title'|trans({}, 'admin') }} · {{ teacher.name.lastName }}, {{ teacher.name.firstName }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto space-y-8">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1 flex-wrap">
            <a href="{{ path('app_educational_centre_index') }}" class="hover:text-plum-600 transition-colors">
                {{ 'educational_centre'|trans({}, 'navigation') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
            <a href="{{ path('app_admin_centre_teachers_index', {centreId: centre.id}) }}" class="hover:text-plum-600 transition-colors">
                {{ 'centre_teachers.title'|trans({}, 'admin') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4 shrink-0'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ teacher.name.lastName }}, {{ teacher.name.firstName }}</h1>
        <p class="mt-1 text-sm text-gray-500">{{ teacher.username }}</p>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-base font-semibold text-gray-900">{{ 'centre_teachers.edit.title'|trans({}, 'admin') }}</h2>
            <p class="mt-0.5 text-sm text-gray-500">{{ 'centre_teachers.edit.hint'|trans({}, 'admin') }}</p>
        </div>

        <form method="post" class="px-6 py-6 space-y-5">
            <input type="hidden" name="_token" value="{{ csrf_token('edit_centre_teacher_groups_' ~ teacher.id) }}">

            <div>
                <label for="group_ids" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'centre_teachers.edit.groups_label'|trans({}, 'admin') }}
                </label>

                {% if all_groups is empty %}
                    <p class="text-sm text-gray-500 italic">{{ 'centre_teachers.edit.no_groups'|trans({}, 'admin') }}</p>
                {% else %}
                    <select id="group_ids" name="group_ids[]" multiple
                            class="w-full text-sm"
                            data-no-results="{{ 'centre_teachers.edit.no_results'|trans({}, 'admin')|e('html_attr') }}"
                            data-placeholder="{{ 'centre_teachers.edit.groups_placeholder'|trans({}, 'admin')|e('html_attr') }}">
                        {% for group in all_groups %}
                            <option value="{{ group.id.toRfc4122 }}"
                                    data-programme="{{ group.programmeYear.programme.name|e('html_attr') }}"
                                    data-level="{{ group.programmeYear.name|e('html_attr') }}"
                                    {{ group.id.toRfc4122 in current_group_ids ? 'selected' : '' }}>
                                {{ group.name }}
                            </option>
                        {% endfor %}
                    </select>
                    <p class="mt-1.5 text-xs text-gray-500">{{ 'centre_teachers.edit.groups_hint'|trans({}, 'admin') }}</p>
                {% endif %}
            </div>

            <div class="flex items-center justify-between pt-2">
                <a href="{{ path('app_admin_teachers_edit', {id: teacher.id}) }}"
                   class="text-sm text-plum-600 hover:text-plum-700 hover:underline transition-colors">
                    {{ 'centre_teachers.edit.link_global_edit'|trans({}, 'admin') }}
                </a>
                {% if all_groups is not empty %}
                    <button type="submit"
                            class="rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                                   hover:bg-plum-700 transition-colors shadow-xs">
                        {{ 'centre_teachers.edit.save'|trans({}, 'admin') }}
                    </button>
                {% endif %}
            </div>
        </form>
    </div>

</div>

{% if all_groups is not empty %}
<script type="module">
import TomSelect from 'tom-select';

const el = document.getElementById('group_ids');
if (el) {

const placeholder = el.dataset.placeholder ?? '';
const noResults   = el.dataset.noResults   ?? '';

const options = [];
el.querySelectorAll('option').forEach(opt => {
    options.push({
        value:     opt.value,
        name:      opt.textContent.trim(),
        programme: opt.dataset.programme ?? '',
        level:     opt.dataset.level     ?? '',
        search:    `${opt.dataset.programme} ${opt.dataset.level} ${opt.textContent.trim()}`,
    });
});

const selected = Array.from(el.selectedOptions).map(o => o.value);

new TomSelect(el, {
    options,
    items:         selected,
    valueField:    'value',
    labelField:    'name',
    searchField:   ['search'],
    create:        false,
    maxOptions:    null,
    placeholder,
    plugins:       ['remove_button', 'checkbox_options'],
    render: {
        option: (d, esc) =>
            `<div class="ts-group-option">
                <p class="ts-group-programme">${esc(d.programme)} <span class="ts-group-level">· ${esc(d.level)}</span></p>
                <p class="ts-group-name">${esc(d.name)}</p>
            </div>`,
        item: (d, esc) =>
            `<div class="ts-group-item" title="${esc(d.programme)} · ${esc(d.level)}">
                <span class="ts-group-item-programme">${esc(d.programme)}</span>
                <span class="ts-sep">·</span>
                <span>${esc(d.name)}</span>
            </div>`,
        no_results: () =>
            `<div class="no-results px-3 py-2 text-sm">${noResults}</div>`,
    },
});

} // end if (el)
</script>
{% endif %}
{% endblock %}
