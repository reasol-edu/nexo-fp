{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'centre.new.title'|trans({}, 'admin') }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto">

    <div class="mb-6">
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
            <a href="{{ path('app_admin') }}" class="hover:text-plum-600 transition-colors">
                {{ 'dashboard.title'|trans({}, 'admin') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
            <a href="{{ path('app_admin_centres_index') }}" class="hover:text-plum-600 transition-colors">
                {{ 'centres.title'|trans({}, 'admin') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ 'centre.new.title'|trans({}, 'admin') }}</h1>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs">
        <form method="post" class="px-6 py-6 space-y-5">
            <input type="hidden" name="_token" value="{{ csrf_token('new_centre') }}">

            {# Código #}
            <div>
                <label for="code" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'centre.field.code'|trans({}, 'admin') }}
                </label>
                <input id="code" type="text" name="code"
                       value="{{ values.code ?? '' }}"
                       maxlength="8"
                       class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                              transition-colors focus:outline-none focus:ring-3
                              {{ errors.code is defined
                                  ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                  : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                <p class="mt-1.5 text-xs text-gray-400">{{ 'centre.field.code_help'|trans({}, 'admin') }}</p>
                {% if errors.code is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.code }}</p>
                {% endif %}
            </div>

            {# Nombre #}
            <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'centre.field.name'|trans({}, 'admin') }}
                </label>
                <input id="name" type="text" name="name"
                       value="{{ values.name ?? '' }}"
                       class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                              transition-colors focus:outline-none focus:ring-3
                              {{ errors.name is defined
                                  ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                  : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                {% if errors.name is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.name }}</p>
                {% endif %}
            </div>

            {# Localidad #}
            <div>
                <label for="city" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'centre.field.city'|trans({}, 'admin') }}
                </label>
                <input id="city" type="text" name="city"
                       value="{{ values.city ?? '' }}"
                       class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                              transition-colors focus:outline-none focus:ring-3
                              {{ errors.city is defined
                                  ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                  : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                {% if errors.city is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.city }}</p>
                {% endif %}
            </div>

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_admin_centres_index') }}"
                   class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm font-medium text-gray-700
                          hover:bg-gray-50 transition-colors">
                    {{ 'centre.cancel'|trans({}, 'admin') }}
                </a>
                <button type="submit"
                        class="rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                               hover:bg-plum-700 transition-colors shadow-xs">
                    {{ 'centre.save'|trans({}, 'admin') }}
                </button>
            </div>
        </form>
    </div>

</div>
{% endblock %}
