{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'teacher.edit.title'|trans({}, 'admin') }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-2xl mx-auto space-y-8">

    <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
            <a href="{{ path('app_admin') }}" class="hover:text-plum-600 transition-colors">
                {{ 'dashboard.title'|trans({}, 'admin') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
            <a href="{{ path('app_admin_teachers_index') }}" class="hover:text-plum-600 transition-colors">
                {{ 'teachers.title'|trans({}, 'admin') }}
            </a>
            {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
        </div>
        <h1 class="text-2xl font-bold text-gray-900">{{ teacher.name.lastName }}, {{ teacher.name.firstName }}</h1>
    </div>

    {# ── Datos del docente ─────────────────────────────────────────────────────── #}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-base font-semibold text-gray-900">{{ 'teacher.edit.title'|trans({}, 'admin') }}</h2>
        </div>
        <form method="post" class="px-6 py-6 space-y-5"
              data-controller="external-auth">
            <input type="hidden" name="_token" value="{{ csrf_token('edit_teacher_' ~ teacher.id) }}">

            {# Nombre y apellidos #}
            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                <div>
                    <label for="first_name" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'teacher.field.first_name'|trans({}, 'admin') }}
                    </label>
                    <input id="first_name" type="text" name="first_name"
                           value="{{ values.first_name }}"
                           class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                  transition-colors focus:outline-none focus:ring-3
                                  {{ errors.first_name is defined
                                      ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                      : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                    {% if errors.first_name is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.first_name }}</p>
                    {% endif %}
                </div>

                <div>
                    <label for="last_name" class="block text-sm font-medium text-gray-700 mb-1.5">
                        {{ 'teacher.field.last_name'|trans({}, 'admin') }}
                    </label>
                    <input id="last_name" type="text" name="last_name"
                           value="{{ values.last_name }}"
                           class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                                  transition-colors focus:outline-none focus:ring-3
                                  {{ errors.last_name is defined
                                      ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                      : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                    {% if errors.last_name is defined %}
                        <p class="mt-1.5 text-xs text-red-600">{{ errors.last_name }}</p>
                    {% endif %}
                </div>
            </div>

            {# Usuario #}
            <div>
                <label for="username" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'teacher.field.username'|trans({}, 'admin') }}
                </label>
                <input id="username" type="text" name="username"
                       value="{{ values.username }}"
                       autocomplete="username"
                       class="block w-full rounded-xl border py-2.5 px-3.5 text-sm font-mono text-gray-900
                              transition-colors focus:outline-none focus:ring-3
                              {{ errors.username is defined
                                  ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                  : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                {% if errors.username is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.username }}</p>
                {% endif %}
            </div>

            {# Email #}
            <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'teacher.field.email'|trans({}, 'admin') }}
                </label>
                <input id="email" type="email" name="email"
                       value="{{ values.email }}"
                       class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                              transition-colors focus:outline-none focus:ring-3
                              {{ errors.email is defined
                                  ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                  : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                {% if errors.email is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.email }}</p>
                {% endif %}
            </div>

            {# Contraseña #}
            <div data-external-auth-target="passwordBlock"
                 style="transition: max-height 0.25s ease, opacity 0.25s ease;">
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1.5">
                    {{ 'teacher.field.password'|trans({}, 'admin') }}
                </label>
                <input id="password" type="password" name="password"
                       placeholder="{{ 'teacher.field.password_edit_help'|trans({}, 'admin') }}"
                       autocomplete="new-password"
                       data-external-auth-target="passwordInput"
                       class="block w-full rounded-xl border py-2.5 px-3.5 text-sm text-gray-900
                              transition-colors focus:outline-none focus:ring-3
                              {{ errors.password is defined
                                  ? 'border-red-300 bg-red-50 focus:border-red-400 focus:ring-red-400/20'
                                  : 'border-gray-200 bg-gray-50 focus:border-plum-500 focus:bg-white focus:ring-plum-500/20' }}">
                {% if errors.password is defined %}
                    <p class="mt-1.5 text-xs text-red-600">{{ errors.password }}</p>
                {% endif %}
            </div>

            {# Opciones #}
            <div class="space-y-3 pt-1">
                <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" name="admin" value="1"
                           {{ flags.admin ? 'checked' : '' }}
                           {{ is_current_user ? 'disabled' : '' }}
                           class="h-4 w-4 rounded border-gray-300 text-plum-600 focus:ring-plum-500">
                    <span class="text-sm text-gray-700">{{ 'teacher.field.admin'|trans({}, 'admin') }}</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" name="active" value="1"
                           {{ flags.active ? 'checked' : '' }}
                           {{ is_current_user ? 'disabled' : '' }}
                           class="h-4 w-4 rounded border-gray-300 text-plum-600 focus:ring-plum-500">
                    <span class="text-sm text-gray-700">{{ 'teacher.field.active'|trans({}, 'admin') }}</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" name="external" value="1"
                           {{ flags.external ? 'checked' : '' }}
                           data-external-auth-target="checkbox"
                           data-action="change->external-auth#toggle"
                           class="h-4 w-4 rounded border-gray-300 text-plum-600 focus:ring-plum-500">
                    <span class="text-sm text-gray-700">{{ 'teacher.field.external'|trans({}, 'admin') }}</span>
                </label>
            </div>

            {% if is_current_user %}
                <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                    {{ 'teacher.self_protection_help'|trans({}, 'admin') }}
                </div>
            {% endif %}

            <div class="flex justify-end pt-2">
                <button type="submit"
                        class="rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                               hover:bg-plum-700 transition-colors shadow-xs">
                    {{ 'teacher.save'|trans({}, 'admin') }}
                </button>
            </div>
        </form>
    </div>

    {# ── Zona peligrosa ───────────────────────────────────────────────────────── #}
    <div class="rounded-2xl border border-red-200 bg-white shadow-xs overflow-hidden">
        <div class="px-6 py-4 border-b border-red-100 bg-red-50">
            <h2 class="text-base font-semibold text-red-700">{{ 'teacher.delete_section'|trans({}, 'admin') }}</h2>
        </div>
        <div class="px-6 py-5 flex items-center justify-between gap-4">
            {% if is_current_user %}
                <p class="text-sm text-red-700">{{ 'teacher.delete_self_blocked'|trans({}, 'admin') }}</p>
            {% else %}
                <p class="text-sm text-gray-600">{{ 'teacher.delete_warning'|trans({}, 'admin') }}</p>
                <form method="post"
                      action="{{ path('app_admin_teachers_delete', {id: teacher.id}) }}"
                      onsubmit="return confirm('{{ 'teachers.delete_confirm'|trans({}, 'admin') }}')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_teacher_' ~ teacher.id) }}">
                    <button type="submit"
                            class="inline-flex items-center gap-2 rounded-xl border border-red-300 px-4 py-2.5 text-sm font-medium
                                   text-red-600 hover:bg-red-50 hover:border-red-400 transition-colors shrink-0">
                        {{ ux_icon('heroicons:trash', {class: 'h-4 w-4'}) }}
                        {{ 'teachers.delete'|trans({}, 'admin') }}
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
