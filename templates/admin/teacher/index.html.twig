{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'teachers.title'|trans({}, 'admin') }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto">

    <div class="mb-6 flex items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                <a href="{{ path('app_admin') }}" class="hover:text-plum-600 transition-colors">
                    {{ 'dashboard.title'|trans({}, 'admin') }}
                </a>
                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
            </div>
            <h1 class="text-2xl font-bold text-gray-900">{{ 'teachers.title'|trans({}, 'admin') }}</h1>
        </div>
        <a href="{{ path('app_admin_teachers_new') }}"
           class="inline-flex items-center gap-2 rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                  hover:bg-plum-700 transition-colors shadow-xs">
            {{ ux_icon('heroicons:plus', {class: 'h-4 w-4'}) }}
            {{ 'teachers.new'|trans({}, 'admin') }}
        </a>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        {% if teachers is empty %}
            <div class="px-6 py-16 text-center">
                {{ ux_icon('heroicons:users', {class: 'mx-auto h-10 w-10 text-gray-300 mb-3'}) }}
                <p class="text-sm text-gray-500">{{ 'teachers.empty'|trans({}, 'admin') }}</p>
            </div>
        {% else %}
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100 bg-gray-50">
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                            {{ 'teachers.name'|trans({}, 'admin') }}
                        </th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                            {{ 'teachers.username'|trans({}, 'admin') }}
                        </th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                            {{ 'teachers.email'|trans({}, 'admin') }}
                        </th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                            {{ 'teachers.roles'|trans({}, 'admin') }}
                        </th>
                        <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">
                            {{ 'teachers.actions'|trans({}, 'admin') }}
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for teacher in teachers %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                <span class="font-medium text-gray-900">{{ teacher.name.lastName }}, {{ teacher.name.firstName }}</span>
                            </td>
                            <td class="px-6 py-4 font-mono text-xs text-gray-600">{{ teacher.username }}</td>
                            <td class="px-6 py-4 text-gray-500 text-xs">
                                {{ teacher.email ?? '—' }}
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-1.5 flex-wrap">
                                    {% if teacher.admin %}
                                        <span class="inline-flex items-center rounded-full bg-plum-50 px-2 py-0.5 text-xs font-medium text-plum-700 ring-1 ring-inset ring-plum-600/20">
                                            {{ 'teachers.badge.admin'|trans({}, 'admin') }}
                                        </span>
                                    {% endif %}
                                    {% if not teacher.active %}
                                        <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/20">
                                            {{ 'teachers.badge.inactive'|trans({}, 'admin') }}
                                        </span>
                                    {% endif %}
                                    {% if teacher.external %}
                                        <span class="inline-flex items-center rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20">
                                            {{ 'teachers.badge.external'|trans({}, 'admin') }}
                                        </span>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="{{ path('app_admin_teachers_edit', {id: teacher.id}) }}"
                                       class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-medium
                                              text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-colors">
                                        {{ ux_icon('heroicons:pencil-square', {class: 'h-3.5 w-3.5'}) }}
                                        {{ 'teachers.edit'|trans({}, 'admin') }}
                                    </a>
                                    {% if app.user and app.user.id == teacher.id %}
                                        <span class="inline-flex items-center gap-1.5 rounded-lg border border-amber-200 px-3 py-1.5 text-xs font-medium text-amber-700 bg-amber-50">
                                            {{ ux_icon('heroicons:shield-exclamation', {class: 'h-3.5 w-3.5'}) }}
                                            {{ 'teacher.delete_self_blocked_short'|trans({}, 'admin') }}
                                        </span>
                                    {% else %}
                                        <form method="post"
                                              action="{{ path('app_admin_teachers_delete', {id: teacher.id}) }}"
                                              onsubmit="return confirm('{{ 'teachers.delete_confirm'|trans({}, 'admin') }}')">
                                            <input type="hidden" name="_token"
                                                   value="{{ csrf_token('delete_teacher_' ~ teacher.id) }}">
                                            <button type="submit"
                                                    class="inline-flex items-center gap-1.5 rounded-lg border border-red-200 px-3 py-1.5 text-xs font-medium
                                                           text-red-600 hover:bg-red-50 hover:border-red-300 transition-colors">
                                                {{ ux_icon('heroicons:trash', {class: 'h-3.5 w-3.5'}) }}
                                                {{ 'teachers.delete'|trans({}, 'admin') }}
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

</div>
{% endblock %}
