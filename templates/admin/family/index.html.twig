{% extends 'layouts/app.html.twig' %}

{% block title %}{{ 'families.title'|trans({}, 'admin') }} · {{ centre.name }} · {{ app_name }}{% endblock %}

{% block content %}
<div class="px-6 py-8 max-w-7xl mx-auto">

    <div class="mb-6 flex items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                <a href="{{ path('app_admin') }}" class="hover:text-plum-600 transition-colors">
                    {{ 'dashboard.title'|trans({}, 'admin') }}
                </a>
                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
                <a href="{{ path('app_admin_centres_index') }}" class="hover:text-plum-600 transition-colors">
                    {{ 'centres.title'|trans({}, 'admin') }}
                </a>
                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
                <a href="{{ path('app_admin_centres_edit', {id: centre.id}) }}" class="hover:text-plum-600 transition-colors">
                    {{ centre.name }}
                </a>
                {{ ux_icon('heroicons:chevron-right', {class: 'h-4 w-4'}) }}
            </div>
            <h1 class="text-2xl font-bold text-gray-900">{{ 'families.title'|trans({}, 'admin') }}</h1>
            {% if centre.activeAcademicYear %}
                <p class="text-sm text-gray-500 mt-0.5">{{ centre.activeAcademicYear.name }}</p>
            {% endif %}
        </div>
        {% if centre.activeAcademicYear %}
            <a href="{{ path('app_admin_families_new', {centreId: centre.id}) }}"
               class="inline-flex items-center gap-2 rounded-xl bg-plum-600 px-4 py-2.5 text-sm font-semibold text-white
                      hover:bg-plum-700 transition-colors shadow-xs">
                {{ ux_icon('heroicons:plus', {class: 'h-4 w-4'}) }}
                {{ 'families.new'|trans({}, 'admin') }}
            </a>
        {% endif %}
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-xs overflow-hidden">
        <twig:Admin:ProfessionalFamilyListComponent :centre="centre" />
    </div>

</div>
{% endblock %}
